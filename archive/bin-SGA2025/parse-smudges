#!/usr/bin/env python
"""Parse the SMUDGes ultra-diffuse-galaxy catalog into a row format
ready for manual splicing into SGA's ``custom-external`` catalog (see
``SGA.external.read_custom_external``).

Reads ``SMUDGes_catalog.6_23.ascii`` (MRT format) from
``{sga_dir()}/parent/external/``, restricts to ``VC == 0`` (a SMUDGes
quality/visual-confirmation flag), then restricts further to
``2*Re > 15`` arcsec (SGA's minimum-diameter cutoff for a "real"
candidate), excluding two named objects whose SMUDGes diameters are
known to be very wrong (hardcoded veto by ``OBJNAME``, listed below).
For each surviving object, converts the half-light radius ``Re``
(arcsec) to a diameter (arcmin, factor of 2/60 -- **not** yet the
Re->RHolm 1.2x correction, which is applied downstream in
``SGA2025-build-parent``'s ``build_parent_nocuts``/
``SGA.parent.build_parent_nocuts``) and wraps ``PA`` into [0, 360) via
plain ``% 360``. Row numbers are captured *before* the ``VC`` cut, so
they still index correctly into the original
``SMUDGes_catalog.6_23.ascii`` file for cross-referencing.

Writes one leading-comma CSV row per object (``OBJTYPE`` is left blank
for the first field, to be filled in by hand after pasting) to
``smudges.txt`` in the current directory. Run this script, then
cut-and-paste the contents of ``smudges.txt`` into the custom catalog.

Reference run (SGA-2025), for provenance:

    Read 7,070 objects from /global/cfs/cdirs/desicollab/users/ioannis/SGA/2025/parent/external/SMUDGes_catalog.6_23.ascii
    Trimmed to 6,805/7,070 objects with VC==0.
    Trimmed to 2,655/6,805 objects with diam>15 arcsec.

The following two objects' SMUDGes diameters are very wrong and are
excluded by hand:

    SMDG J2152023-642205,328.00947,-64.36812,3.652333333333333,0.51,292.05,13.14,r,Row 6671 in 'SMUDGes_catalog.6_23.ascii'
    SMDG J0052040-352127,13.01655,-35.35749,4.142,0.51,306.84000000000003,14.68,r,Row 295 in 'SMUDGes_catalog.6_23.ascii'

"""
import os
import numpy as np
from astropy.table import Table
from SGA.io import sga_dir

base_smdgfile = 'SMUDGes_catalog.6_23.ascii'
smdgfile = os.path.join(sga_dir(), 'parent', 'external', base_smdgfile)
smdg = Table.read(smdgfile, format='mrt')
smdg['ROW'] = np.arange(len(smdg))
print(f'Read {len(smdg):,d} objects from {smdgfile}')
smdg['OBJNAME'] = np.char.replace(smdg['SMDG'].value, 'SMDG', 'SMDG J')
I = smdg['VC'] == 0
print(f'Trimmed to {np.sum(I):,d}/{len(smdg):,d} objects with VC==0')
smdg = smdg[I]

# see notes above
rem = ~np.isin(smdg['OBJNAME'], ['SMDG J2152023-642205', 'SMDG J0052040-352127'])

I = ((2. * smdg['Re'].value) > 15.) * rem
print(f'Trimmed to {np.sum(I):,d}/{len(smdg):,d} objects with diam>15 arcsec')

F = open('smudges.txt', 'w')
for obj in smdg[I]:
    objname = obj['OBJNAME']
    ra = obj['RAdeg']
    dec = obj['DEdeg']
    # see SGA2025-build-parent (build_parent_nocuts) for one more
    # factor of 1.2 to go from Re to RHolm
    diam = obj['Re'] * 2. / 60. # [radius in arcsec --> diameter in arcmin]
    ba = obj['b/a']
    pa = obj['PA'] % 360 # [-90,90] --> [0,360]
    rmag = obj['rmag']
    row = obj['ROW']
    F.write(f",{objname},{ra},{dec},{diam},{ba},{pa},{rmag},r,Row {row} in '{base_smdgfile}'\n")
F.close()

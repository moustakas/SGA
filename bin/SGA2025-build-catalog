# Characters allowed in a galaxy name. Square brackets are included because
# several NED-searchable catalog prefixes use them (e.g. [CGB2022], [KK98]).
_SAFE_GALAXY_RE = re.compile(r'^[a-zA-Z0-9 +\-._:\[\]]+$')

# Known catalog-name prefixes that should always be fully uppercased.
# Longer alternatives (e.g. UGCA) must precede shorter ones (UGC) so the
# alternation matches the longest prefix first.
_PREFIX_NORM_RE = re.compile(
    r'^(2MASX|UGCA|UGC|NGC|IC|PGC|ESO|MCG|ARP|MRK|DDO|KDG|'
    r'VCC|FCC|CGCG|HIPASS|SDSS|SBS|KUG|UZC|MGC|HCG)(?=[\s\d\-])',
    re.IGNORECASE
)

def _normalize_galaxy_prefix(name):
    """Uppercase known catalog-name prefixes (e.g. 'Mrk 231' -> 'MRK 231')."""
    return _PREFIX_NORM_RE.sub(lambda m: m.group(0).upper(), name, count=1)

# Matches leading zeros in numeric sequences not preceded by another digit,
# e.g. "KKR 03" -> "KKR 3", "F08D1" -> "F8D1".
_ZERO_PAD_RE = re.compile(r'(?<!\d)0+(?=\d)')

def _strip_zero_pad(s):
    """Lowercase, strip spaces, strip leading zeros from digit sequences."""
    return _ZERO_PAD_RE.sub('', s.lower().replace(' ', ''))

# Matches the LVD catalog's short Messier form (e.g. 'M 33', 'M81'), used to
# alias it to SGA's OBJNAME convention ('MESSIER 033', 'MESSIER 081').
MESSIER_RE = re.compile(r'^M\s*(\d+)$', re.IGNORECASE)

# Priority-ordered catalog prefixes for "famous name" promotion. When CROSSIDS
# contains multiple names, the highest-priority match is promoted to GALAXY
# regardless of NED's own choice. Prefixes absent from this list (2MASX, SDSS,
# WISE, ICRF, etc.) are never actively promoted but remain as GALAXY when
# nothing better is available. Note: ^IC\b does not match ICRF (no word
# boundary between C and R).
_PREFERRED_PREFIXES = [
    re.compile(r'^Messier\b', re.IGNORECASE),
    re.compile(r'^NGC\b',     re.IGNORECASE),
    re.compile(r'^IC\b',      re.IGNORECASE),
    re.compile(r'^UGCA?\b',   re.IGNORECASE),  # matches both UGCA and UGC
    re.compile(r'^ESO\b',     re.IGNORECASE),
    re.compile(r'^ESO-LV\b',  re.IGNORECASE),
    re.compile(r'^MCG\b',     re.IGNORECASE),
    re.compile(r'^ARP\b',     re.IGNORECASE),
    re.compile(r'^MRK\b',     re.IGNORECASE),
    re.compile(r'^DDO\b',     re.IGNORECASE),
    re.compile(r'^KDG\b',     re.IGNORECASE),
    re.compile(r'^VCC\b',     re.IGNORECASE),
    re.compile(r'^BK\b',      re.IGNORECASE),
    re.compile(r'^JKB\b',     re.IGNORECASE),
    re.compile(r'^CGCG\b',    re.IGNORECASE),
    re.compile(r'^PGC\b',     re.IGNORECASE),
    re.compile(r'^PGC1\b',    re.IGNORECASE),
    re.compile(r'^AGC\b',     re.IGNORECASE),
    re.compile(r'^FCC\b',     re.IGNORECASE),
    re.compile(r'^HCG\b',     re.IGNORECASE),
    re.compile(r'^HIPASS\b',  re.IGNORECASE),
    # Lower-priority survey prefixes: promoted over SDSS/WISEA/GALEX etc.,
    # but only when no higher-priority catalog name is present.
    re.compile(r'^\[CGB2022\]', re.IGNORECASE),
    re.compile(r'^ELVES dw\b',  re.IGNORECASE),
]

def _find_preferred_idx(parts):
    """Return index of highest-priority catalog name in parts, or -1 if none."""
    for pat in _PREFERRED_PREFIXES:
        for j, p in enumerate(parts):
            if pat.match(p):
                return j
    return -1


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
class _ListHandler(logging.Handler):
    """Logging handler that appends formatted records to a plain list, so the
    full run (including messages logged by imported SGA modules, which share
    the same singleton logger) can be replayed to a single ASCII file."""
    def __init__(self, lines):
        super().__init__()
        self.lines = lines

    def emit(self, record):
        self.lines.append(self.format(record))


def _detect_bands(beta):
    """Infer (optical) bands and all_bands from beta catalog column names."""
    bands     = [re.sub(r'^R26_', '', c)
                 for c in beta.colnames if re.match(r'^R26_[A-Z]+$', c)]
    all_bands = [re.sub(r'^COG_MTOT_', '', c)
                 for c in beta.colnames if re.match(r'^COG_MTOT_[A-Z0-9]+$', c)]
    return bands, all_bands


def _build_dm_ref(bands, all_bands):
    """1-row SGA_datamodel reference table for dtype/unit lookup (no data copy)."""
    dummy = Table({'SGAID': np.zeros(1, np.int64)})
    return SGA_datamodel(dummy, bands, all_bands, copy=False)


def _fix_dtypes(beta, dm):
    """Cast beta columns whose dtype does not match the SGA_datamodel reference.

    Byte-order differences (e.g. >f4 vs float32) are not considered mismatches;
    only kind (f/i/u/S/U) and itemsize are compared.
    """
    fixes = []
    for col in dm.colnames:
        if col not in beta.colnames:
            continue
        ref = dm[col].dtype
        cur = beta[col].dtype
        if cur.kind != ref.kind or cur.itemsize != ref.itemsize:
            beta[col] = beta[col].astype(ref)
            fixes.append((col, str(cur), str(ref)))
    return fixes


def _strval(v):
    """Return a stripped Python str, decoding bytes if necessary."""
    if isinstance(v, (bytes, np.bytes_)):
        return v.decode().strip()
    return str(v).strip()


def _str_arr_dtype(col):
    """Return a numpy Unicode dtype wide enough for the string column col."""
    dt = col.dtype
    if dt.kind == 'U':
        return dt
    if dt.kind == 'S':
        return f'U{dt.itemsize}'
    return 'U100'


def _angular_sep_arcsec(ra1, dec1, ra2, dec2):
    """Small-angle angular separation in arcsec; ra2/dec2 may be arrays."""
    cos_dec = np.cos(np.radians(dec1))
    return np.sqrt(((ra2 - ra1) * cos_dec)**2 + (dec2 - dec1)**2) * 3600.


def _vdiff_kms(z1, z2):
    """Rest-frame velocity difference (km/s) between two redshifts; scalar
    or array. Same formula as the Z_FLAG_DISCREPANCY check below."""
    return C_LIGHT * np.abs(z1 - z2) / (1. + np.minimum(z1, z2))


def _helio_to_cmb_z(ra, dec, z_helio):
    """Convert heliocentric redshift to the CMB frame (non-relativistic; the
    solar velocity relative to the CMB, ~370 km/s, is negligible relative to
    c at the redshifts this catalog covers).

    ra/dec: degrees (float or array). z_helio: dimensionless (float or array).
    """
    apex = SkyCoord(ra=CMB_APEX_RA_DEG * u.degree, dec=CMB_APEX_DEC_DEG * u.degree)
    coord = SkyCoord(ra=np.asarray(ra) * u.degree, dec=np.asarray(dec) * u.degree)
    cos_theta = np.cos(coord.separation(apex).radian)
    return z_helio + CMB_APEX_V_KMS * cos_theta / C_LIGHT


def _select_desi(rows, sga_ra, sga_dec, max_sep_arcsec):
    """Select the best DESI spectrum for one SGA galaxy.

    rows          : numpy structured array — all match rows for this SGAID.
    sga_ra/dec    : SGA galaxy center (degrees).
    max_sep_arcsec: maximum allowed separation between SGA center and
                    DESI TARGET_RA/TARGET_DEC (excludes background objects).

    Returns the selected row (numpy.void) or None if no good spectrum exists.

    Note: target-bit logic (e.g. BGS_TARGET != 0) could be used to break
    ties before DELTACHI2, but is omitted because secondary-program
    observations are equally valid redshift sources.
    """
    # Step 0: proximity filter — only spectra near the SGA center
    seps = _angular_sep_arcsec(sga_ra, sga_dec,
                                rows['TARGET_RA'], rows['TARGET_DEC'])
    rows = rows[seps <= max_sep_arcsec]
    if len(rows) == 0:
        return None

    # Step 1: deduplicate repeat observations of the same TARGETID
    primary = rows[rows['ZCAT_PRIMARY'].astype(bool)]
    if len(primary) == 0:
        return None

    # Step 1b: drop physically implausible spectra regardless of ZWARN
    spectypes = np.array([_strval(s) for s in primary['SPECTYPE']])
    zvals     = primary['Z'].astype(float)
    valid     = (
        (spectypes != 'STAR') &
        ~((spectypes == 'GALAXY') & (zvals > 1.0)) &
        ~((spectypes == 'QSO')    & (zvals > 1.0))
    )
    primary   = primary[valid]
    spectypes = spectypes[valid]
    if len(primary) == 0:
        return None

    good = primary['ZWARN'] == 0

    # Step 2: prefer GALAXY + ZWARN==0; fall back to any ZWARN==0
    pool = primary[(spectypes == 'GALAXY') & good]
    if len(pool) == 0:
        pool = primary[good]
    if len(pool) == 0:
        return None

    # Step 3: highest DELTACHI2
    return pool[np.argmax(pool['DELTACHI2'])]


def _select_sdss(rows):
    """Select the best SDSS DR17 spectrum for one SGA galaxy.

    rows: numpy structured array -- all match rows for this SGAID, already
    restricted to "best" extragalactic spectra and a fixed search radius by
    SGA2025-desi-dr1-match --sdss. Drop Z > 1.0 (GALAXY or QSO) as physically
    implausible for this sample, mirroring the DESI cut. Among the survivors,
    the only remaining choice is the closest match (by SEP_ARCSEC) when more
    than one falls within that radius. Returns None if none survive.
    """
    rows = rows[rows['Z'] <= 1.0]
    if len(rows) == 0:
        return None
    return rows[np.argmin(rows['SEP_ARCSEC'])]


def load_vi_redshifts(path):
    """Load a VI worksheet CSV (see SGA2025-qa-redshifts).

    Returns dict[int SGAID -> dict(status, z, z_ivar)] for rows with
    VI_STATUS in ('ok', 'discard', 'override'); rows with a blank or other
    VI_STATUS (not yet reviewed) are skipped. Returns {} if path is None.
    """
    out = {}
    if not path:
        return out
    with open(path, newline='') as f:
        for row in csv.DictReader(f):
            status = row.get('VI_STATUS', '').strip().lower()
            if status not in ('ok', 'discard', 'override'):
                continue
            try:
                sid = int(row['SGAID'])
            except (KeyError, ValueError):
                continue
            out[sid] = {'status': status, 'z': row.get('VI_Z', ''),
                       'z_ivar': row.get('VI_Z_IVAR', '')}
    return out


def _reorder_cols(tbl):
    """Reorder tbl columns per COL_ORDER; append unlisted columns at the end."""
    unknown = [c for c in COL_ORDER if c not in tbl.colnames]
    if unknown:
        log.warning(f'COL_ORDER references unknown columns: {unknown}')
    listed    = [c for c in COL_ORDER if c in tbl.colnames]
    remaining = [c for c in tbl.colnames if c not in set(listed)]
    return tbl[listed + remaining]


# ---------------------------------------------------------------------------
# Per-region merge
# ---------------------------------------------------------------------------
def merge_region(region, neddir, redshiftdir, outdir, vdiff_threshold,
                 desi_max_sep, lvd_catalog=None, parent_nocuts=None,
                 ned_override_zmin=0.3, vi_redshifts=None, lines=None):
    def emit(msg=''):
        print(msg)
        if lines is not None:
            lines.append(msg)

    log.info(f'=== {region} ===')

    # --- SGA beta catalog -------------------------------------------------
    log.info('  Loading SGA beta catalog')
    _, beta = read_sga_sample(region=region, beta=True)
    _, tractor = read_sga_sample(region=region, beta=True, tractor=True)
    bands, all_bands = _detect_bands(beta)
    log.info(f'  Detected bands={bands}  all_bands={all_bands}')
    dm    = _build_dm_ref(bands, all_bands)
    fixes = _fix_dtypes(beta, dm)
    if fixes:
        for col, old, new in fixes:
            log.info(f'  dtype fix: {col}  {old} -> {new}')
    n = len(beta)
    log.info(f'  {n:,d} galaxies')

    # --- One-time fix: dr11-north RESOLVED objects mistakenly tagged BANDS=griz ---
    # (dr11-south RESOLVED objects with BANDS=griz are legitimate and untouched.)
    if region == 'dr11-north':
        I = (beta['ELLIPSEMODE'] & ELLIPSEMODE['RESOLVED'] != 0) & (beta['BANDS'] == 'griz')
        if np.any(I):
            log.info(f'  One-time fix: {int(np.sum(I)):,d} RESOLVED objects with BANDS=griz -> grz')
            beta['BANDS'][I] = 'grz'

    # --- Parent/nocuts catalog (initial geometry) --------------------------------
    init_arrs = None
    if parent_nocuts:
        log.info(f'  Loading parent/nocuts catalog {parent_nocuts}')
        vv = Table(fitsio.read(parent_nocuts))
        parent_idx = {int(r['ROW_PARENT']): i for i, r in enumerate(vv)}
        par_rows = np.array([parent_idx.get(int(sid), -1) for sid in beta['SGAID']])
        has_match = par_rows >= 0
        log.info(f'  {int(np.sum(has_match)):,d}/{n:,d} beta galaxies matched to parent/nocuts catalog')
        mm = vv[par_rows[has_match]]
        diam_arcsec, ba_init, pa_init, ref_init, mag_init, _ = \
            choose_geometry(mm, mindiam=30., get_mag=True)
        init_arrs = {
            'RA_INIT':       np.full(n, -1., np.float64),
            'DEC_INIT':      np.full(n, -1., np.float64),
            'DIAM_INIT':     np.full(n, -1., np.float32),
            'BA_INIT':       np.full(n, -1., np.float32),
            'PA_INIT':       np.full(n, -1., np.float32),
            'MAG_INIT':      np.full(n, -1., np.float32),
            'INIT_REF': np.full(n, '', dtype='U14'),
        }
        init_arrs['RA_INIT'][has_match]       = mm['RA']
        init_arrs['DEC_INIT'][has_match]      = mm['DEC']
        init_arrs['DIAM_INIT'][has_match]     = (diam_arcsec / 60.).astype(np.float32)
        init_arrs['BA_INIT'][has_match]       = ba_init.astype(np.float32)
        init_arrs['PA_INIT'][has_match]       = pa_init.astype(np.float32)
        init_arrs['MAG_INIT'][has_match]      = mag_init.astype(np.float32)
        init_arrs['INIT_REF'][has_match] = ref_init

        # Fallback: custom catalog (VI-inspected sources added to the parent)
        customfile = resources.files('SGA').joinpath(
            'data/SGA2025/SGA2025-parent-custom.csv')
        cust = Table.read(str(customfile), format='csv', comment='#')
        custom_lookup = {
            str(r['OBJNAME']).strip(): (
                float(r['RA']), float(r['DEC']),
                float(r['DIAM_LIT']), float(r['BA_LIT']), float(r['PA_LIT']))
            for r in cust
        }

        # Fallback: versioned adds.csv files; alphabetical sort = version order,
        # so first-seen entry is from the earliest version.
        overlays_dir = Path(str(
            resources.files('SGA').joinpath('data/SGA2025/overlays')))
        adds_lookup = {}
        for fpath in sorted(overlays_dir.glob('*/adds.csv')):
            for r in Table.read(str(fpath), format='csv'):
                name = str(r['OBJNAME']).strip()
                if name not in adds_lookup:
                    adds_lookup[name] = (
                        float(r['RA']), float(r['DEC']),
                        float(r['DIAM']), float(r['BA']), float(r['PA']))

        n_from_custom = 0
        n_from_adds   = 0
        for i in np.where(init_arrs['RA_INIT'] < 0.)[0]:
            name = str(beta['OBJNAME'][i]).strip()
            if name in custom_lookup:
                ra, dec, diam_arcsec, ba, pa = custom_lookup[name]
                src = 'custom'
            elif name in adds_lookup:
                ra, dec, diam_arcsec, ba, pa = adds_lookup[name]
                src = 'adds'
            else:
                continue
            init_arrs['RA_INIT'][i]       = ra
            init_arrs['DEC_INIT'][i]      = dec
            init_arrs['DIAM_INIT'][i]     = np.float32(diam_arcsec / 60.)
            init_arrs['BA_INIT'][i]       = np.float32(ba)
            init_arrs['PA_INIT'][i]       = np.float32(pa)
            init_arrs['INIT_REF'][i] = 'VI'
            if src == 'custom':
                n_from_custom += 1
            else:
                n_from_adds += 1

        log.info(f'  {n_from_custom:,d} objects filled from custom catalog; '
                 f'{n_from_adds:,d} from adds.csv')
        n_still_missing = int(np.sum(init_arrs['RA_INIT'] < 0.))
        if n_still_missing > 0:
            log.warning(f'  {n_still_missing:,d} objects still missing INIT geometry')

        # Hand-fix: a handful of objects have DIAM_INIT recorded in arcsec
        # instead of arcmin — divide by 60 to correct.
        _diam_arcsec_objnames = {
            'WISEA J110950.68+331807.2',
            'IRAS 14220+3138',
            '2MASXi J0032468-345652',
            'IRAS 12337+5044',
            '2MFGC 04926',
            'KK 166',
        }
        objname_arr = np.array([str(v).strip() for v in beta['OBJNAME']])
        for i, name in enumerate(objname_arr):
            if name in _diam_arcsec_objnames and init_arrs['DIAM_INIT'][i] > 0.:
                init_arrs['DIAM_INIT'][i] = np.float32(init_arrs['DIAM_INIT'][i] / 60.)

        # Floor: set any valid but unrealistically small DIAM_INIT to 0.5 arcmin.
        tiny = (init_arrs['DIAM_INIT'] > 0.) & (init_arrs['DIAM_INIT'] < 0.1)
        if np.any(tiny):
            log.warning(f'  Setting {int(np.sum(tiny)):,d} DIAM_INIT < 0.1 arcmin to 0.5 arcmin')
            init_arrs['DIAM_INIT'][tiny] = np.float32(0.5)

    # --- NED merged catalog -----------------------------------------------
    ned_path     = os.path.join(neddir, f'ned-merged-{region}.fits')
    log.info(f'  Loading {ned_path}')
    ned_tbl      = Table(fitsio.read(ned_path))
    ned_by_sgaid = {int(r['SGAID']): r for r in ned_tbl}

    # --- LVD catalog (distance takes precedence over NED for LVD objects) ---
    # Match by OBJNAME (plus a Messier short-form alias, e.g. 'M 33' ->
    # 'MESSIER 033'); distance and errors converted from kpc to Mpc.
    lvd_by_name = {}
    if lvd_catalog:
        log.info(f'  Loading LVD catalog {lvd_catalog}')
        lvd = Table.read(lvd_catalog)
        # confirmed_real: 1/0/masked. Drop only explicit 0 (rejected);
        # masked (unreviewed for this flag, e.g. long-known Messier
        # galaxies) is kept -- np.asarray() on a masked column silently
        # fills masked entries as 0, so the mask must be checked explicitly.
        is_masked = np.ma.getmaskarray(lvd['confirmed_real'])
        keep      = is_masked | (np.asarray(lvd['confirmed_real']) != 0)
        n_dropped = int(np.sum(~keep))
        if n_dropped:
            log.info(f'  Dropping {n_dropped:,d}/{len(lvd):,d} LVD entries with confirmed_real=0')
        lvd = lvd[keep]
        for r in lvd:
            name = str(r['name'])
            lvd_by_name[name] = r
            m = MESSIER_RE.match(name.strip())
            if m:
                lvd_by_name[f'MESSIER {int(m.group(1)):03d}'] = r
        is_lvd      = (beta['SAMPLE'].value & SAMPLE_BITS['LVD']) != 0
        log.info(f'  LVD catalog: {len(lvd):,d} entries; '
                 f'{int(np.sum(is_lvd)):,d} LVD objects in SGA sample')

    # --- VI worksheet (manual redshift overrides; see SGA2025-qa-redshifts) -
    vi_lookup = load_vi_redshifts(vi_redshifts)
    if vi_redshifts:
        log.info(f'  VI worksheet {vi_redshifts}: {len(vi_lookup):,d} reviewed SGAIDs')

    # --- DESI summary (N_DESI per galaxy) ---------------------------------
    sum_path   = os.path.join(redshiftdir,
                              f'SGA2025-DESI-DR1-summary-{region}.fits')
    log.info(f'  Loading {sum_path}')
    summary    = fitsio.read(sum_path, columns=['SGAID', 'N_DESI'])
    ndesi_lookup = {int(r['SGAID']): int(r['N_DESI']) for r in summary}
    ndesi_arr  = np.array([ndesi_lookup.get(int(sid), 0)
                           for sid in beta['SGAID']], dtype=np.int32)

    # --- DESI matches (all spectra within SGA ellipses) -------------------
    match_path = os.path.join(redshiftdir,
                              f'SGA2025-DESI-DR1-matches-{region}.fits')
    log.info(f'  Loading {match_path}')
    matches    = fitsio.read(match_path)
    log.info(f'  {len(matches):,d} DESI match rows')

    grp = defaultdict(list)
    for i in range(len(matches)):
        grp[int(matches['SGAID'][i])].append(i)
    log.info(f'  {len(grp):,d} unique SGAIDs with DESI matches')

    # --- SDSS DR17 matches (optional; graceful if not yet generated) ------
    sdss_match_path = os.path.join(redshiftdir,
                                   f'SGA2025-SDSS-DR17-matches-{region}.fits')
    sdss_matches = None
    sdss_grp     = {}
    if os.path.exists(sdss_match_path):
        log.info(f'  Loading {sdss_match_path}')
        sdss_matches = fitsio.read(sdss_match_path)
        log.info(f'  {len(sdss_matches):,d} SDSS match rows')
        sdss_grp = defaultdict(list)
        for i in range(len(sdss_matches)):
            sdss_grp[int(sdss_matches['SGAID'][i])].append(i)
        log.info(f'  {len(sdss_grp):,d} unique SGAIDs with SDSS matches')
    else:
        log.info(f'  {sdss_match_path} not found, skipping SDSS redshifts '
                 '(run SGA2025-desi-dr1-match --sdss to generate)')

    # --- Pre-allocate output arrays ---------------------------------------
    # DESI: redshifts/IVARs sentinel 0., IDs sentinel -1, strings ''
    desi_arrs = {
        'TARGETID_DESI':  np.full(n, -1,           np.int64),
        'SURVEY_DESI':    np.full(n, '',            dtype='U7'),
        'PROGRAM_DESI':   np.full(n, '',            dtype='U6'),
        'Z_DESI':         np.zeros(n,               np.float64),
        'Z_IVAR_DESI':     np.zeros(n,               np.float64),
        'ZWARN_DESI':     np.full(n, -1,            np.int64),
        'DELTACHI2_DESI': np.full(n, FLOAT_SENTINEL, np.float64),
        'SPECTYPE_DESI':  np.full(n, '',            dtype='U6'),
        'NSPEC_DESI':     ndesi_arr,
    }

    # SDSS: redshifts/IVARs sentinel 0., strings '' (including SPECOBJID_SDSS)
    sdss_arrs = {
        'SPECOBJID_SDSS': np.full(n, '', dtype='U22'),
        'Z_SDSS':         np.zeros(n,    np.float64),
        'Z_IVAR_SDSS':    np.zeros(n,    np.float64),
        'CLASS_SDSS':     np.full(n, '', dtype='U6'),
    }

    # NED: columns with IVAR companions use 0. sentinel; others use FLOAT_SENTINEL
    ned_arrs = {}
    for src, dst, _ in NED_CARRY:
        if src not in ned_tbl.colnames:
            continue
        col = ned_tbl[src]
        if col.dtype.kind == 'f':
            sentinel = 0. if dst in NED_ZERO_SENTINEL else FLOAT_SENTINEL
            ned_arrs[dst] = np.full(n, sentinel, col.dtype)
        elif col.dtype.kind in ('i', 'u'):
            ned_arrs[dst] = np.zeros(n, col.dtype)
        else:
            ned_arrs[dst] = np.full(n, '', dtype=_str_arr_dtype(col))
    ned_arrs['Z_IVAR_NED']    = np.zeros(n, np.float64)  # from NED_Z_UNC
    ned_arrs['DIST_IVAR_NED'] = np.zeros(n, np.float32)  # from NED_DIST_UNC

    # Adopted redshift
    adopted_arrs = {
        'Z':      np.zeros(n, np.float64),
        'Z_IVAR':  np.zeros(n, np.float64),
        'Z_REF':  np.full(n, '', dtype='U4'),
        'Z_FLAG': np.zeros(n, np.int16),
    }

    # Adopted distance (LVD preferred over NED when available).
    # 0. sentinel — DIST_IVAR=0 signals no measurement.
    dist_arrs = {
        'DIST':          np.zeros(n, np.float32),
        'DIST_IVAR':     np.zeros(n, np.float32),
        'DIST_REF':      np.full(n, '', dtype='U4'),
        'DIST_LVD':      np.zeros(n, np.float32),
        'DIST_IVAR_LVD': np.zeros(n, np.float32),
    }

    # LVD redshifts (from vlos_systemic / vlos_sigma in km/s).
    lvd_z_arrs = {
        'Z_LVD':      np.zeros(n, np.float64),
        'Z_IVAR_LVD': np.zeros(n, np.float64),
    }

    # Convenient handles
    z_ned_arr     = ned_arrs.get('Z_NED')
    zivar_ned_arr = ned_arrs.get('Z_IVAR_NED')

    # --- Main resolution loop --------------------------------------------
    log.info(f'  Resolving redshifts (desi_max_sep={desi_max_sep:.1f}")')
    n_lvd_sample_added = 0
    for i in range(n):
        sid     = int(beta['SGAID'][i])
        sga_ra  = float(beta['RA'][i])
        sga_dec = float(beta['DEC'][i])

        # DESI selection
        if sid in grp:
            best = _select_desi(matches[grp[sid]], sga_ra, sga_dec, desi_max_sep)
            if best is not None:
                zerr = float(best['ZERR'])
                desi_arrs['TARGETID_DESI'][i]  = int(best['TARGETID'])
                desi_arrs['SURVEY_DESI'][i]    = _strval(best['SURVEY'])
                desi_arrs['PROGRAM_DESI'][i]   = _strval(best['PROGRAM'])
                desi_arrs['Z_DESI'][i]         = float(best['Z'])
                desi_arrs['Z_IVAR_DESI'][i]     = 1. / zerr**2 if zerr > 0. else 0.
                desi_arrs['ZWARN_DESI'][i]     = int(best['ZWARN'])
                desi_arrs['DELTACHI2_DESI'][i] = float(best['DELTACHI2'])
                desi_arrs['SPECTYPE_DESI'][i]  = _strval(best['SPECTYPE'])

        # SDSS DR17 selection
        if sid in sdss_grp:
            sbest = _select_sdss(sdss_matches[sdss_grp[sid]])
            if sbest is not None:
                zerr  = float(sbest['Z_ERR'])
                sdss_arrs['SPECOBJID_SDSS'][i] = _strval(sbest['SPECOBJID'])
                sdss_arrs['Z_SDSS'][i]         = float(sbest['Z'])
                sdss_arrs['Z_IVAR_SDSS'][i]    = 1. / zerr**2 if zerr > 0. else 0.
                sdss_arrs['CLASS_SDSS'][i]     = _strval(sbest['CLASS'])

        # NED columns
        nrow = ned_by_sgaid.get(sid)
        if nrow is not None:
            for src, dst, _ in NED_CARRY:
                if dst not in ned_arrs:
                    continue
                val = nrow[src]
                arr = ned_arrs[dst]
                if arr.dtype.kind == 'f':
                    try:
                        fv = float(val)
                        arr[i] = fv if np.isfinite(fv) else (
                            0. if dst in NED_ZERO_SENTINEL else FLOAT_SENTINEL)
                    except (ValueError, TypeError):
                        pass  # sentinel already in place
                elif arr.dtype.kind in ('i', 'u'):
                    try:
                        arr[i] = int(val)
                    except (ValueError, TypeError):
                        pass
                else:
                    arr[i] = _strval(val)

            # Z_IVAR_NED: from NED_Z_UNC
            if 'NED_Z_UNC' in ned_tbl.colnames:
                try:
                    z_unc = float(nrow['NED_Z_UNC'])
                except (ValueError, TypeError):
                    z_unc = 0.
                z_ned_val = z_ned_arr[i] if z_ned_arr is not None else 0.
                if z_ned_val != 0. or z_unc > 0.:
                    err = z_unc if z_unc > 0. else NED_Z_NOMINAL_ERR
                    ned_arrs['Z_IVAR_NED'][i] = 1. / err**2

            # DIST_IVAR_NED: from NED_DIST_UNC; 0. if no error reported
            if 'NED_DIST_UNC' in ned_tbl.colnames:
                try:
                    dist_unc = float(nrow['NED_DIST_UNC'])
                except (ValueError, TypeError):
                    dist_unc = 0.
                dist_ned = ned_arrs['DIST_NED'][i]
                if dist_ned > 0. and dist_unc > 0.:
                    ned_arrs['DIST_IVAR_NED'][i] = np.float32(1. / dist_unc**2)

        # LVD redshifts and distances (matched by OBJNAME)
        objname = _strval(beta['OBJNAME'][i])
        if objname in lvd_by_name:
            lrow = lvd_by_name[objname]
            if not (beta['SAMPLE'][i] & SAMPLE_BITS['LVD']):
                beta['SAMPLE'][i] |= SAMPLE_BITS['LVD']
                n_lvd_sample_added += 1
            def _lvd_val(v):
                if np.ma.is_masked(v):
                    return float('nan')
                try:
                    return float(v)
                except (TypeError, ValueError):
                    return float('nan')
            # Z_LVD from vlos_systemic (km/s -> dimensionless z)
            vlos = _lvd_val(lrow['vlos_systemic'])
            em = _lvd_val(lrow['vlos_systemic_em'])
            ep = _lvd_val(lrow['vlos_systemic_ep'])
            if np.isfinite(vlos):
                lvd_z_arrs['Z_LVD'][i] = vlos / C_LIGHT
                mean_err = 0.5 * (em + ep)
                if np.isfinite(mean_err) and mean_err > 0.:
                    lvd_z_arrs['Z_IVAR_LVD'][i] = (C_LIGHT / mean_err)**2
            # DIST_LVD from distance (kpc -> Mpc)
            d_mpc = _lvd_val(lrow['distance']) / 1000.
            em    = _lvd_val(lrow['distance_em']) / 1000.
            ep    = _lvd_val(lrow['distance_ep']) / 1000.
            if np.isfinite(d_mpc) and d_mpc > 0.:
                dist_arrs['DIST_LVD'][i] = np.float32(d_mpc)
                mean_err = 0.5 * (em + ep)
                if np.isfinite(mean_err) and mean_err > 0.:
                    dist_arrs['DIST_IVAR_LVD'][i] = np.float32(1. / mean_err**2)

        # Adopted redshift: LVD > DESI > SDSS > NED
        zivar_desi = desi_arrs['Z_IVAR_DESI'][i]
        z_desi     = desi_arrs['Z_DESI'][i]
        zivar_sdss = sdss_arrs['Z_IVAR_SDSS'][i]
        z_sdss     = sdss_arrs['Z_SDSS'][i]
        zivar_lvd  = lvd_z_arrs['Z_IVAR_LVD'][i]
        z_lvd      = lvd_z_arrs['Z_LVD'][i]
        zivar_ned  = zivar_ned_arr[i] if zivar_ned_arr is not None else 0.
        z_ned      = z_ned_arr[i]     if z_ned_arr     is not None else 0.

        if zivar_lvd > 0.:
            adopted_arrs['Z'][i]      = z_lvd
            adopted_arrs['Z_IVAR'][i] = zivar_lvd   # may be 0. if vlos_sigma missing
            adopted_arrs['Z_REF'][i]  = 'LVD'
        elif zivar_desi > 0.:
            adopted_arrs['Z'][i]      = z_desi
            adopted_arrs['Z_IVAR'][i] = zivar_desi
            adopted_arrs['Z_REF'][i]  = 'DESI'
        elif zivar_sdss > 0.:
            adopted_arrs['Z'][i]      = z_sdss
            adopted_arrs['Z_IVAR'][i] = zivar_sdss
            adopted_arrs['Z_REF'][i]  = 'SDSS'
        elif zivar_ned > 0.:
            adopted_arrs['Z'][i]      = z_ned
            adopted_arrs['Z_IVAR'][i] = zivar_ned
            adopted_arrs['Z_REF'][i]  = 'NED'

        # Z_FLAG: large velocity discrepancy between any two measured redshifts
        z_valid = []
        if z_lvd  != 0.:   z_valid.append(z_lvd)
        if zivar_desi > 0.: z_valid.append(z_desi)
        if zivar_sdss > 0.: z_valid.append(z_sdss)
        if zivar_ned  > 0.: z_valid.append(z_ned)
        for j in range(len(z_valid) - 1):
            for zb in z_valid[j + 1:]:
                if C_LIGHT * abs(z_valid[j] - zb) / (1. + min(z_valid[j], zb)) > vdiff_threshold:
                    adopted_arrs['Z_FLAG'][i] |= Z_FLAG_DISCREPANCY

        # Z_FLAG: propagate NED_FLAG when NED is the *sole* redshift measurement
        # (no LVD, DESI, or SDSS value at all, so DISCREPANCY above can never
        # fire and would otherwise silently miss a still-suspect/unresolved
        # NED redshift).
        if len(z_valid) == 1 and zivar_ned > 0.:
            ned_flag = int(ned_arrs['NED_FLAG'][i]) if 'NED_FLAG' in ned_arrs else 0
            if ned_flag & NED_FLAG_Z_SUSPECT:
                adopted_arrs['Z_FLAG'][i] |= Z_FLAG_NED_SUSPECT
            if ned_flag & NED_FLAG_Z_UNRESOLVED:
                adopted_arrs['Z_FLAG'][i] |= Z_FLAG_NED_UNRESOLVED
            if ned_flag & NED_FLAG_Z_MISSING:
                adopted_arrs['Z_FLAG'][i] |= Z_FLAG_NED_MISSING

        # Adopted distance: LVD preferred, then NED
        dist_ned      = ned_arrs['DIST_NED'][i]
        dist_ivar_ned = ned_arrs['DIST_IVAR_NED'][i]
        dist_lvd      = dist_arrs['DIST_LVD'][i]
        dist_ivar_lvd = dist_arrs['DIST_IVAR_LVD'][i]
        if dist_lvd > 0.:
            dist_arrs['DIST'][i]      = dist_lvd
            dist_arrs['DIST_IVAR'][i] = dist_ivar_lvd
            dist_arrs['DIST_REF'][i]  = 'LVD'
        elif dist_ned > 0.:
            dist_arrs['DIST'][i]      = dist_ned
            dist_arrs['DIST_IVAR'][i] = dist_ivar_ned   # may be 0. if no error
            dist_arrs['DIST_REF'][i]  = 'NED'

    # --- Consensus override: DESI outlier vs. an agreeing SDSS/NED pair ----
    n_consensus = 0
    if z_ned_arr is not None and zivar_ned_arr is not None:
        z_desi, z_sdss = desi_arrs['Z_DESI'], sdss_arrs['Z_SDSS']
        three_valid = ((desi_arrs['Z_IVAR_DESI'] > 0.) &
                       (sdss_arrs['Z_IVAR_SDSS'] > 0.) & (zivar_ned_arr > 0.))
        agree_ds = _vdiff_kms(z_desi, z_sdss)    <= vdiff_threshold
        agree_dn = _vdiff_kms(z_desi, z_ned_arr) <= vdiff_threshold
        agree_sn = _vdiff_kms(z_sdss, z_ned_arr) <= vdiff_threshold
        consensus_mask = three_valid & ~agree_ds & ~agree_dn & agree_sn
        n_consensus = int(np.sum(consensus_mask))
        if n_consensus:
            adopted_arrs['Z'][consensus_mask]      = z_sdss[consensus_mask]
            adopted_arrs['Z_IVAR'][consensus_mask] = sdss_arrs['Z_IVAR_SDSS'][consensus_mask]
            adopted_arrs['Z_REF'][consensus_mask]  = 'SDSS'
            adopted_arrs['Z_FLAG'][consensus_mask] = Z_FLAG_CONSENSUS_OVERRIDE
    log.info(f'  Consensus override (DESI outlier, SDSS+NED agree): {n_consensus:,d} objects')

    # --- Automatic NED override for high-z DESI/SDSS (see docstring) -------
    n_auto = 0
    if z_ned_arr is not None and zivar_ned_arr is not None:
        already_resolved = (adopted_arrs['Z_FLAG'] & Z_FLAG_CONSENSUS_OVERRIDE) != 0
        auto_mask = (~already_resolved &
                    (adopted_arrs['Z'] > ned_override_zmin) &
                    np.isin(adopted_arrs['Z_REF'], ['DESI', 'SDSS']) &
                    (zivar_ned_arr > 0.))
        n_auto = int(np.sum(auto_mask))
    if n_auto:
        adopted_arrs['Z'][auto_mask]      = z_ned_arr[auto_mask]
        adopted_arrs['Z_IVAR'][auto_mask] = zivar_ned_arr[auto_mask]
        adopted_arrs['Z_REF'][auto_mask]  = 'NED'
        adopted_arrs['Z_FLAG'][auto_mask] = Z_FLAG_AUTO_NED_OVERRIDE
    log.info(f'  Auto NED override (DESI/SDSS Z>{ned_override_zmin:g}): {n_auto:,d} objects')

    # --- Apply VI worksheet overrides (see load_vi_redshifts) --------------
    if vi_lookup:
        n_vi = {'ok': 0, 'discard': 0, 'override': 0}
        sgaid_arr = np.array(beta['SGAID'])
        for i, sid in enumerate(sgaid_arr):
            vi = vi_lookup.get(int(sid))
            if vi is None:
                continue
            n_vi[vi['status']] += 1
            if vi['status'] == 'discard':
                adopted_arrs['Z'][i]      = 0.
                adopted_arrs['Z_IVAR'][i] = 0.
                adopted_arrs['Z_REF'][i]  = ''
            elif vi['status'] == 'override':
                adopted_arrs['Z'][i]      = float(vi['z'])
                adopted_arrs['Z_IVAR'][i] = float(vi['z_ivar'])
                adopted_arrs['Z_REF'][i]  = 'VI'
            adopted_arrs['Z_FLAG'][i] = Z_FLAG_VI_REVIEWED
        log.info(f'  VI applied: {n_vi["ok"]:,d} ok, {n_vi["discard"]:,d} discarded, '
                 f'{n_vi["override"]:,d} overridden')

    # --- Peculiar-velocity-corrected ("cosmological") redshift, via pvhub -
    cosmo_arrs = {
        'Z_COSMO':      np.zeros(n, np.float64),
        'Z_COSMO_IVAR': np.zeros(n, np.float64),
    }
    has_z = adopted_arrs['Z_IVAR'] > 0.
    n_has_z = int(np.sum(has_z))
    if n_has_z:
        ra_z    = np.array(beta['RA'])[has_z]
        dec_z   = np.array(beta['DEC'])[has_z]
        z_z     = adopted_arrs['Z'][has_z]
        zivar_z = adopted_arrs['Z_IVAR'][has_z]

        zcmb_z = _helio_to_cmb_z(ra_z, dec_z, z_z)
        vcmb_z = C_LIGHT * zcmb_z

        # Default (also the fallback beyond pvhub's domain): CMB-frame
        # redshift, no flow-field peculiar-velocity correction applied.
        zcosmo_z      = zcmb_z.copy()
        zcosmo_ivar_z = zivar_z.copy()

        in_pvhub = vcmb_z < PVHUB_VCMB_MAX_KMS
        n_pvhub  = int(np.sum(in_pvhub))
        if n_pvhub and get_models is not None:
            ra_pv    = ra_z[in_pvhub]
            dec_pv   = dec_z[in_pvhub]
            zcmb_pv  = zcmb_z[in_pvhub]
            zivar_pv = zivar_z[in_pvhub]

            pv_models = []
            for model_class in get_models():
                try:
                    model = model_class()
                    pv = np.asarray(model.calculate_pv(ra_pv, dec_pv, zcmb_pv), dtype=np.float64)
                except Exception as e:
                    log.warning(f'  pvhub model {model_class.__name__} failed, skipping: {e}')
                    continue
                pv_models.append(pv)

            if pv_models:
                pv_stack = np.vstack(pv_models)  # (n_models, n_pvhub)
                n_valid  = np.sum(np.isfinite(pv_stack), axis=0)
                # Columns where every model failed are all-NaN; nanmean/nanstd
                # warn ("Mean of empty slice", "Degrees of freedom <= 0") but
                # correctly return NaN, which `have_pv` below already handles.
                with np.errstate(invalid='ignore'), warnings.catch_warnings():
                    warnings.simplefilter('ignore', category=RuntimeWarning)
                    pv_mean = np.nanmean(pv_stack, axis=0)
                    pv_std  = np.nanstd(pv_stack, axis=0)
                pv_std[n_valid < 2] = 0.  # no model-scatter estimate from <2 models

                have_pv = np.isfinite(pv_mean)
                zcosmo_pv = zcmb_pv.copy()
                zcosmo_pv[have_pv] = (1. + zcmb_pv[have_pv]) / (1. + pv_mean[have_pv] / C_LIGHT) - 1.

                zerr_meas  = 1. / np.sqrt(zivar_pv)
                zerr_model = pv_std / C_LIGHT
                zerr_total = np.sqrt(zerr_meas**2 + zerr_model**2)
                zcosmo_ivar_pv = np.where(have_pv, 1. / zerr_total**2, zivar_pv)

                zcosmo_z[in_pvhub]      = zcosmo_pv
                zcosmo_ivar_z[in_pvhub] = zcosmo_ivar_pv
        elif n_pvhub and get_models is None:
            log.warning(f'  pvhub not installed -- Z_COSMO will carry the CMB-frame '
                        f'redshift with no peculiar-velocity correction for '
                        f'{n_pvhub:,d} objects with v_cmb < {PVHUB_VCMB_MAX_KMS:.0f} km/s '
                        f'(see etc/README.md, "Optional: pvhub")')

        cosmo_arrs['Z_COSMO'][has_z]      = zcosmo_z
        cosmo_arrs['Z_COSMO_IVAR'][has_z] = zcosmo_ivar_z
        log.info(f'  Z_COSMO: {n_has_z:,d}/{n:,d} objects with Z_IVAR>0, '
                 f'{n_pvhub:,d} within pvhub domain (v_cmb < {PVHUB_VCMB_MAX_KMS:.0f} km/s)')

    # --- GALAXY and ALTNAMES from CROSSIDS --------------------------------
    crossids_col = ned_arrs.get('CROSSIDS')
    galaxy_arr   = np.full(n, '', dtype='U35')
    altnames_arr = np.full(n, '', dtype='U200')
    if crossids_col is not None:
        for i, crossids in enumerate(crossids_col):
            parts = [p.strip() for p in crossids.split('|') if p.strip()]
            if not parts:
                continue
            primary = parts[0]
            if 'HOST' in primary.upper() and len(parts) > 1:
                promoted_idx = next(
                    (j for j in range(1, len(parts)) if 'HOST' not in parts[j].upper()),
                    None
                )
                if promoted_idx is not None:
                    promoted  = parts[promoted_idx]
                    remaining = parts[1:promoted_idx] + parts[promoted_idx + 1:]
                    if primary.upper() not in {r.upper() for r in remaining}:
                        remaining.append(primary)
                    parts = [promoted] + remaining
            # Promote highest-priority "famous" catalog name if not already first
            pref_idx = _find_preferred_idx(parts)
            if pref_idx > 0:
                parts = [parts[pref_idx]] + parts[:pref_idx] + parts[pref_idx + 1:]
            galaxy = parts[0]
            rest   = [p for p in parts[1:] if p.upper() != galaxy.upper()]
            # Prefer an ALTNAME without special characters when GALAXY has them
            if not _SAFE_GALAXY_RE.match(galaxy):
                alt_idx = next((j for j, p in enumerate(rest) if _SAFE_GALAXY_RE.match(p)), None)
                if alt_idx is not None:
                    promoted = rest[alt_idx]
                    rest     = [galaxy] + rest[:alt_idx] + rest[alt_idx + 1:]
                    galaxy   = promoted
            galaxy        = _normalize_galaxy_prefix(galaxy)
            galaxy_arr[i] = galaxy
            # Normalize prefixes on ALTNAME candidates, then deduplicate case-insensitively
            seen = {galaxy.upper()}
            deduped_rest = []
            for p in rest:
                p_norm = _normalize_galaxy_prefix(p)
                if p_norm.upper() not in seen:
                    seen.add(p_norm.upper())
                    deduped_rest.append(p_norm)
            altnames_arr[i] = '|'.join(deduped_rest[:3])

    # Fill GALAXY from OBJNAME when NED returned no match
    objnames = np.array([str(v).strip() for v in beta['OBJNAME']])
    empty = galaxy_arr == ''
    if np.any(empty):
        log.warning(f'  GALAXY empty for {int(np.sum(empty)):,d} objects; copying from OBJNAME')
        galaxy_arr[empty] = objnames[empty]

    # OBJNAME-based promotion: after catalog-prefix promotion, if an ALTNAMES entry
    # contains OBJNAME as a case-insensitive substring, promote it to GALAXY.
    # Also checks a weaker condition: if the last whitespace-token of an ALTNAMES
    # entry (length ≥ 4) appears inside OBJNAME — this handles cases like
    # OBJNAME="CenA-MM-Dw1" matching ALTNAMES="Centaurus A:[CSC2014] MM-Dw1".
    for i in range(n):
        objname = objnames[i]
        if not objname or galaxy_arr[i] == '' or galaxy_arr[i].lower() == objname.lower():
            continue
        alt_parts = [p for p in altnames_arr[i].split('|') if p]
        if not alt_parts:
            continue
        obj_lower = objname.lower()
        match_idx = None
        for j, alt in enumerate(alt_parts):
            alt_lower = alt.lower()
            if obj_lower in alt_lower:
                match_idx = j
                break
            toks = alt_lower.split()
            if toks and len(toks[-1]) >= 4 and toks[-1] in obj_lower:
                match_idx = j
                break
            if _strip_zero_pad(obj_lower) == _strip_zero_pad(alt_lower):
                match_idx = j
                break
        if match_idx is not None:
            promoted  = alt_parts[match_idx]
            old_gal   = galaxy_arr[i]
            remaining = [p for k, p in enumerate(alt_parts) if k != match_idx]
            if old_gal.upper() not in {p.upper() for p in remaining}:
                remaining = [old_gal] + remaining
            galaxy_arr[i]   = promoted
            altnames_arr[i] = '|'.join(remaining[:3])

    # Apply hand-curated name corrections; keep old GALAXY in ALTNAMES so it
    # remains discoverable, and remove the new GALAXY from ALTNAMES to avoid
    # duplicating it there.
    for j, g in enumerate(galaxy_arr):
        if g in GALAXY_OVERRIDES:
            new_g = GALAXY_OVERRIDES[g]
            galaxy_arr[j] = new_g
            existing = [p for p in altnames_arr[j].split('|') if p]
            existing = [p for p in existing if p.upper() != new_g.upper()]
            if g.upper() != new_g.upper() and g.upper() not in {p.upper() for p in existing}:
                existing = [g] + existing
            altnames_arr[j] = '|'.join(existing[:3])

    assert not np.any(galaxy_arr == ''), 'GALAXY is empty after all fixes'

    # --- Assemble output Table -------------------------------------------
    out = beta.copy()

    # Propagate units from SGA_datamodel reference
    for col in dm.colnames:
        if col in out.colnames and dm[col].unit is not None:
            out[col].unit = dm[col].unit

    # New identification columns derived from NED CROSSIDS
    out.add_column(Column(galaxy_arr,   name='GALAXY'))
    out.add_column(Column(altnames_arr, name='ALTNAMES'))

    # DESI columns
    for name, dtype, unit in DESI_COLS:
        out.add_column(Column(desi_arrs[name], name=name, unit=unit))

    # SDSS columns
    for name, dtype, unit in SDSS_COLS:
        out.add_column(Column(sdss_arrs[name], name=name, unit=unit))

    # NED columns: Z_IVAR_NED after Z_NED; DIST_IVAR_NED after DIST_NED
    for src, dst, unit in NED_CARRY:
        if dst not in ned_arrs:
            continue
        out.add_column(Column(ned_arrs[dst], name=dst, unit=unit))
        if dst == 'Z_NED':
            out.add_column(Column(ned_arrs['Z_IVAR_NED'],    name='Z_IVAR_NED'))
        elif dst == 'DIST_NED':
            out.add_column(Column(ned_arrs['DIST_IVAR_NED'], name='DIST_IVAR_NED',
                                  unit=u.Mpc**-2))

    # Adopted redshift
    for name, dtype, unit in ADOPTED_COLS:
        out.add_column(Column(adopted_arrs[name], name=name, unit=unit))

    # Adopted distance
    for name, dtype, unit in DIST_COLS:
        out.add_column(Column(dist_arrs[name], name=name, unit=unit))

    # LVD redshifts
    for name, dtype, unit in LVD_Z_COLS:
        out.add_column(Column(lvd_z_arrs[name], name=name, unit=unit))

    # Peculiar-velocity-corrected ("cosmological") redshift
    for name, dtype, unit in COSMO_COLS:
        out.add_column(Column(cosmo_arrs[name], name=name, unit=unit))

    # Drop columns not wanted in the output
    for col in DROP_COLS:
        if col in out.colnames:
            out.remove_column(col)

    # Initial geometry restored from parent/nocuts catalog (added
    # after drop to avoid collision with drifted beta INIT columns)
    if init_arrs is not None:
        for name, dtype, unit in INIT_COLS:
            out.add_column(Column(init_arrs[name], name=name, unit=unit))

        # Recompute LARGESHIFT using the restored RA_INIT/DEC_INIT as the
        # reference position, replacing the value set during iterative processing.
        _LARGESHIFT  = np.int32(16)
        ra_init      = init_arrs['RA_INIT']
        dec_init     = init_arrs['DEC_INIT']
        have_init    = ra_init > -1.
        sep          = _angular_sep_arcsec(ra_init, dec_init,
                                           np.array(beta['RA']),
                                           np.array(beta['DEC']))
        ebit         = np.array(out['ELLIPSEBIT'], dtype=np.int32)
        ebit        &= ~_LARGESHIFT
        ebit[have_init & (sep > MAXSHIFT_ARCSEC)] |= _LARGESHIFT
        out['ELLIPSEBIT'] = ebit
        log.info(f'  LARGESHIFT recomputed (threshold={MAXSHIFT_ARCSEC}"): '
                 f'{int(np.sum((ebit & _LARGESHIFT) != 0)):,d} objects flagged')

    # Apply column ordering
    out = _reorder_cols(out)

    # --- Write output ----------------------------------------------------
    os.makedirs(outdir, exist_ok=True)
    version = SGA_version(catalog=True)
    outpath = os.path.join(outdir, f'SGA2025-{region}-{version}.fits')
    vals, names, units = table_to_fitsio(out)
    tractor_vals, tractor_names, tractor_units = table_to_fitsio(tractor)
    with fitsio.FITS(outpath, 'rw', clobber=True) as F:
        F.write(vals, names=names, units=units, extname='SGA2025')
        F.write(tractor_vals, names=tractor_names, units=tractor_units, extname='TRACTOR')
    log.info(f'  Wrote {outpath}')

    # --- Summary statistics (stdout) -------------------------------------
    pct        = lambda k: 100. * k / n if n else 0.
    src_arr    = adopted_arrs['Z_REF']
    flag_arr   = adopted_arrs['Z_FLAG']

    n_src_desi  = int(np.sum(src_arr == 'DESI'))
    n_src_sdss  = int(np.sum(src_arr == 'SDSS'))
    n_src_lvd   = int(np.sum(src_arr == 'LVD'))
    n_src_ned   = int(np.sum(src_arr == 'NED'))
    n_src_none  = int(np.sum(src_arr == ''))
    n_disc      = int(np.sum((flag_arr & Z_FLAG_DISCREPANCY)    != 0))
    n_ned_susp  = int(np.sum((flag_arr & Z_FLAG_NED_SUSPECT)    != 0))
    n_ned_unres = int(np.sum((flag_arr & Z_FLAG_NED_UNRESOLVED) != 0))
    n_ned_miss  = int(np.sum((flag_arr & Z_FLAG_NED_MISSING)    != 0))
    n_consensus_ov = int(np.sum((flag_arr & Z_FLAG_CONSENSUS_OVERRIDE) != 0))
    n_auto_ned  = int(np.sum((flag_arr & Z_FLAG_AUTO_NED_OVERRIDE) != 0))
    n_vi_rev    = int(np.sum((flag_arr & Z_FLAG_VI_REVIEWED)    != 0))
    n_desi_prox = int(np.sum((desi_arrs['NSPEC_DESI'] > 0) & (desi_arrs['Z_IVAR_DESI'] == 0.)))
    n_z_lvd      = int(np.sum(lvd_z_arrs['Z_LVD'] != 0.))
    n_z_lvd_ivar = int(np.sum(lvd_z_arrs['Z_IVAR_LVD'] > 0.))

    n_dist_ned  = int(np.sum(ned_arrs['DIST_NED'] > 0.))
    n_dist_ivar = int(np.sum(ned_arrs['DIST_IVAR_NED'] > 0.))
    n_dist_lvd  = int(np.sum(dist_arrs['DIST_LVD'] > 0.))
    n_dist_ivar_lvd = int(np.sum(dist_arrs['DIST_IVAR_LVD'] > 0.))
    n_dist_adopted  = int(np.sum(dist_arrs['DIST'] > 0.))
    n_dist_ref_lvd  = int(np.sum(np.array(dist_arrs['DIST_REF']) == 'LVD'))
    n_dist_ref_ned  = int(np.sum(np.array(dist_arrs['DIST_REF']) == 'NED'))

    emit(f'\n--- {region} summary ({n:,d} galaxies) ---')
    emit(f'  desi_max_sep={desi_max_sep:.1f}"  vdiff_threshold={vdiff_threshold:.0f} km/s')
    if fixes:
        emit('  Dtype fixes: ' +
              ', '.join(f'{c}: {o} -> {nw}' for c, o, nw in fixes))
    emit()
    emit(f'  Z_REF = DESI : {n_src_desi:>8,d}  ({pct(n_src_desi):5.1f}%)')
    emit(f'  Z_REF = SDSS : {n_src_sdss:>8,d}  ({pct(n_src_sdss):5.1f}%)')
    emit(f'  Z_REF = LVD  : {n_src_lvd:>8,d}  ({pct(n_src_lvd):5.1f}%)')
    emit(f'  Z_REF = NED  : {n_src_ned:>8,d}  ({pct(n_src_ned):5.1f}%)')
    emit(f'  Z_REF = none : {n_src_none:>8,d}  ({pct(n_src_none):5.1f}%)')
    emit()
    emit(f'  Z_LVD present (vlos_systemic): {n_z_lvd:>8,d}  ({pct(n_z_lvd):5.1f}%)')
    emit(f'  Z_LVD with IVAR (vlos_sigma) : {n_z_lvd_ivar:>8,d}  ({pct(n_z_lvd_ivar):5.1f}%)')
    emit(f'  SAMPLE LVD bit newly set (name match, not already flagged): '
         f'{n_lvd_sample_added:>8,d}  ({pct(n_lvd_sample_added):5.1f}%)')
    emit()
    emit(f'  Z_FLAG discrepancy           : {n_disc:>8,d}  ({pct(n_disc):5.1f}%)')
    emit(f'  Z_FLAG NED suspect (sole meas): {n_ned_susp:>8,d}  ({pct(n_ned_susp):5.1f}%)')
    emit(f'  Z_FLAG NED unresolved (sole) : {n_ned_unres:>8,d}  ({pct(n_ned_unres):5.1f}%)')
    emit(f'  Z_FLAG NED missing (sole)    : {n_ned_miss:>8,d}  ({pct(n_ned_miss):5.1f}%)')
    emit(f'  Z_FLAG consensus override    : {n_consensus_ov:>8,d}  ({pct(n_consensus_ov):5.1f}%)')
    emit(f'  Z_FLAG auto NED override     : {n_auto_ned:>8,d}  ({pct(n_auto_ned):5.1f}%)')
    emit(f'  Z_FLAG VI-reviewed           : {n_vi_rev:>8,d}  ({pct(n_vi_rev):5.1f}%)')
    emit(f'  NSPEC_DESI>0, no good central z: {n_desi_prox:>8,d}  ({pct(n_desi_prox):5.1f}%)')
    emit()
    emit(f'  DIST_NED present             : {n_dist_ned:>8,d}  ({pct(n_dist_ned):5.1f}%)')
    emit(f'  DIST_NED with IVAR           : {n_dist_ivar:>8,d}  ({pct(n_dist_ivar):5.1f}%)')
    emit(f'  DIST_LVD present             : {n_dist_lvd:>8,d}  ({pct(n_dist_lvd):5.1f}%)')
    emit(f'  DIST_LVD with IVAR           : {n_dist_ivar_lvd:>8,d}  ({pct(n_dist_ivar_lvd):5.1f}%)')
    emit(f'  Adopted DIST present         : {n_dist_adopted:>8,d}  ({pct(n_dist_adopted):5.1f}%)')
    emit(f'    DIST_REF = LVD             : {n_dist_ref_lvd:>8,d}')
    emit(f'    DIST_REF = NED             : {n_dist_ref_ned:>8,d}')
    emit()
    emit('  NSPEC_DESI distribution:')
    nspec = desi_arrs['NSPEC_DESI']
    for label, mask in [
            ('= 0',    nspec == 0),
            ('= 1',    nspec == 1),
            ('2-9',   (nspec >= 2)   & (nspec <= 9)),
            ('10-99', (nspec >= 10)  & (nspec <= 99)),
            ('>= 100', nspec >= 100)]:
        k = int(np.sum(mask))
        emit(f'    {label:>6} : {k:>8,d}  ({pct(k):5.1f}%)')


# ---------------------------------------------------------------------------
# Region merge: combine dr11-south and dr11-north into a single catalog
# ---------------------------------------------------------------------------
GOOD_BANDS = ['G', 'R', 'I', 'Z']

def merge_regions(outdir, lines=None):
    """Merge the per-region SGA2025-{region}-{version}.fits catalogs into a
    single SGA2025-{version}.fits catalog.

    Objects with data in both regions (REGION has both dr11-south and
    dr11-north bits set) are deduplicated by keeping the row with more
    "good" bands (FMASKED_AP00_{band} < 0.5 for band in GOOD_BANDS). Ties
    are broken by preferring whichever side has a good r-band when only
    one does, then by defaulting to dr11-south -- dr11-north's z-band is
    substantially worse, so ties should favor south in nearly all cases.

    Objects whose REGION indicates both regions but which appear as a lone
    row (no counterpart in the other region -- some pixels overlap the
    other region's footprint but not enough to yield a processed object
    there) have REGION corrected down to the single region they actually
    came from.

    lines : list, optional
        If given, every emitted message is also appended here (shared with
        the calling driver so the whole run's log can be written to a
        single ASCII file); otherwise messages just go to stdout.
    """
    version = SGA_version(catalog=True)
    def emit(msg=''):
        print(msg)
        if lines is not None:
            lines.append(msg)

    emit('=== merging dr11-south + dr11-north ===')

    regions  = ['dr11-south', 'dr11-north']
    cats     = {}
    tractors = {}
    for region in regions:
        path = os.path.join(outdir, f'SGA2025-{region}-{version}.fits')
        emit(f'  Loading {path}')
        cats[region]     = Table(fitsio.read(path, ext='SGA2025'))
        tractors[region] = Table(fitsio.read(path, ext='TRACTOR'))

    src = np.concatenate([
        np.full(len(cats[region]), REGIONBITS[region], dtype=np.int16)
        for region in regions
    ])
    cat     = vstack([cats[r]     for r in regions], join_type='exact')
    tractor = vstack([tractors[r] for r in regions], join_type='exact')
    assert len(cat) == len(tractor)
    assert np.array_equal(np.asarray(cat['SGAID']), np.asarray(tractor['REF_ID']))

    n_south, n_north = len(cats['dr11-south']), len(cats['dr11-north'])
    emit(f'  {n_south:,d} dr11-south + {n_north:,d} dr11-north = {len(cat):,d} rows before dedup')

    # --- REGION self-heal: lone rows carrying both bits but only actually
    #     present in one region get REGION corrected to their true region.
    both_bits  = REGIONBITS['dr11-south'] | REGIONBITS['dr11-north']
    sgaid      = np.asarray(cat['SGAID'])
    _, inverse, counts = np.unique(sgaid, return_inverse=True, return_counts=True)
    group_size = counts[inverse]
    region_col = np.asarray(cat['REGION']).copy()
    orphan     = (group_size == 1) & (region_col == both_bits) & (region_col != src)
    if np.any(orphan):
        emit(f'  Correcting REGION for {int(np.sum(orphan)):,d} lone objects '
             f'incorrectly flagged as present in both regions:')
        for i in np.where(orphan)[0]:
            emit(f'    SGAID={sgaid[i]}  OBJNAME={str(cat["OBJNAME"][i]).strip()}  '
                 f'REGION {region_col[i]} -> {src[i]}')
        region_col[orphan] = src[orphan]
        cat['REGION'] = region_col.astype(cat['REGION'].dtype)

    # --- Deduplicate objects with data in both regions ---------------------
    both = (region_col & REGIONBITS['dr11-south'] != 0) & (region_col & REGIONBITS['dr11-north'] != 0)
    ngood = np.zeros(len(cat), dtype=np.int8)
    for b in GOOD_BANDS:
        ngood += (np.asarray(cat[f'FMASKED_AP00_{b}']) < 0.5).astype(np.int8)
    rgood = np.asarray(cat['FMASKED_AP00_R']) < 0.5

    keep = np.ones(len(cat), dtype=bool)
    n_dup = n_south_win = n_north_win = n_tie_rband = n_tie_south = 0
    for sid in np.unique(sgaid[both]):
        idx = np.where(sgaid == sid)[0]
        if len(idx) < 2:
            continue  # already resolved by the REGION self-heal above
        n_dup += 1
        i_s = idx[src[idx] == REGIONBITS['dr11-south']][0]
        i_n = idx[src[idx] == REGIONBITS['dr11-north']][0]
        if ngood[i_s] > ngood[i_n]:
            winner = i_s; n_south_win += 1
        elif ngood[i_n] > ngood[i_s]:
            winner = i_n; n_north_win += 1
        elif rgood[i_s] and not rgood[i_n]:
            winner = i_s; n_tie_rband += 1
        elif rgood[i_n] and not rgood[i_s]:
            winner = i_n; n_tie_rband += 1
        else:
            winner = i_s; n_tie_south += 1
        keep[i_n if winner == i_s else i_s] = False

    emit(f'  {n_dup:,d} objects with data in both regions')
    emit(f'    resolved by more good bands: south={n_south_win:,d}  north={n_north_win:,d}')
    emit(f'    tied on good bands, resolved by r-band: {n_tie_rband:,d}')
    emit(f'    tied on good bands and r-band, defaulted to south: {n_tie_south:,d}')

    merged         = _reorder_cols(cat[keep])
    merged_tractor = tractor[keep]
    emit(f'  {len(merged):,d} galaxies in merged catalog')

    # --- Write output --------------------------------------------------
    outpath = os.path.join(outdir, f'SGA2025-{version}.fits')
    vals, names, units = table_to_fitsio(merged)
    tractor_vals, tractor_names, tractor_units = table_to_fitsio(merged_tractor)
    with fitsio.FITS(outpath, 'rw', clobber=True) as F:
        F.write(vals, names=names, units=units, extname='SGA2025')
        F.write(tractor_vals, names=tractor_names, units=tractor_units, extname='TRACTOR')
    emit(f'  Wrote {outpath}')


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument('--neddir', required=True,
                        help='Directory containing ned-merged-{region}.fits')
    parser.add_argument('--redshiftdir', required=True,
                        help='Directory containing DESI DR1 summary and matches files')
    parser.add_argument('--outdir', required=True,
                        help='Output directory for SGA2025-{region}-{version}.fits')
    parser.add_argument('--region', choices=['dr11-south', 'dr11-north'],
                        help='Process one region only (default: both)')
    parser.add_argument('--vdiff-threshold', type=float, default=1000.,
                        help='DESI/NED velocity discrepancy threshold in km/s '
                             '(default: 1000)')
    parser.add_argument('--desi-max-sep', type=float, default=3.5,
                        help='Max separation between SGA center and DESI '
                             'TARGET_RA/DEC in arcsec (default: 3.5)')
    parser.add_argument('--lvd-catalog',
                        help='Path to LVD ECSV catalog (e.g. lvd_comb_all_v1.1.0.ecsv); '
                             'distances in kpc converted to Mpc')
    parser.add_argument('--parent-nocuts',
                        help='Path to SGA2025-parent-nocuts-v0.10.fits; restores '
                             'RA_INIT/DEC_INIT/DIAM_INIT/INIT_REF/BA_INIT/PA_INIT '
                             'from the original parent catalog geometry')
    parser.add_argument('--ned-override-zmin', type=float, default=0.3,
                        help='Adopted DESI/SDSS redshifts above this value are automatically '
                             'replaced by an independent NED measurement, if one exists '
                             '(default: 0.3)')
    parser.add_argument('--vi-redshifts',
                        help='Path to a VI worksheet CSV (see SGA2025-qa-redshifts) applied '
                             'after the normal Z/Z_IVAR/Z_REF resolution')
    args = parser.parse_args()

    regions = [args.region] if args.region else ['dr11-south', 'dr11-north']

    # When processing both regions, capture the full run -- per-region
    # progress/warnings (including messages logged by imported SGA modules,
    # which share this same singleton logger) and the merge summary -- to a
    # single ASCII file alongside the merged catalog.
    lines, handler = None, None
    if args.region is None:
        lines   = []
        handler = _ListHandler(lines)
        handler.setFormatter(LOGFMT)
        log.addHandler(handler)

    for region in regions:
        merge_region(region, args.neddir, args.redshiftdir, args.outdir,
                     args.vdiff_threshold, args.desi_max_sep,
                     lvd_catalog=args.lvd_catalog,
                     parent_nocuts=args.parent_nocuts,
                     ned_override_zmin=args.ned_override_zmin,
                     vi_redshifts=args.vi_redshifts, lines=lines)

    if args.region is None:
        merge_regions(args.outdir, lines=lines)

        log.removeHandler(handler)
        version = SGA_version(catalog=True)
        os.makedirs(args.outdir, exist_ok=True)
        logpath = os.path.join(args.outdir, f'SGA2025-merge-{version}.txt')
        with open(logpath, 'w') as fh:
            fh.write('\n'.join(lines) + '\n')
        print(f'Wrote {logpath}')


if __name__ == '__main__':
    main()

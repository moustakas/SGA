    'COG_LNALPHA2_FUV', 'COG_LNALPHA2_NUV',
    'COG_LNALPHA2_ERR_G', 'COG_LNALPHA2_ERR_R', 'COG_LNALPHA2_ERR_I', 'COG_LNALPHA2_ERR_Z',
    'COG_LNALPHA2_ERR_W1', 'COG_LNALPHA2_ERR_W2', 'COG_LNALPHA2_ERR_W3', 'COG_LNALPHA2_ERR_W4',
    'COG_LNALPHA2_ERR_FUV', 'COG_LNALPHA2_ERR_NUV',
    'COG_CHI2_G', 'COG_CHI2_R', 'COG_CHI2_I', 'COG_CHI2_Z',
    'COG_CHI2_W1', 'COG_CHI2_W2', 'COG_CHI2_W3', 'COG_CHI2_W4',
    'COG_CHI2_FUV', 'COG_CHI2_NUV',
    'COG_NDOF_G', 'COG_NDOF_R', 'COG_NDOF_I', 'COG_NDOF_Z',
    'COG_NDOF_W1', 'COG_NDOF_W2', 'COG_NDOF_W3', 'COG_NDOF_W4',
    'COG_NDOF_FUV', 'COG_NDOF_NUV',
    # --- Processing / initialization metadata ---
    #'BX', 'BY', 'BX_INIT', 'BY_INIT',
    #'RA_INIT', 'DEC_INIT',
    #'SMA_INIT', 'DIAM_INIT', 'DIAM_INIT_REF',
    #'BA_INIT', 'PA_INIT', 'MAG_INIT',
    #'OPTFLUX',
    #'SMA_MASK',
    #'FITMODE',
]

# ---------------------------------------------------------------------------
# NED columns to carry into the output catalog.
# Tuples: (source col in ned-merged file, output col name, astropy unit).
# NED_Z_UNC  -> Z_IVAR_NED    is computed in the main loop, not listed here.
# NED_DIST_UNC -> DIST_IVAR_NED is computed in the main loop, not listed here.
# ---------------------------------------------------------------------------
NED_CARRY = [
    #('NED_NAME',          'NED_NAME',       None),
    ('CROSSIDS',          'CROSSIDS',       None),
    ('NED_Z',             'Z_NED',          None),
    # Z_IVAR_NED inserted after Z_NED in assembly (computed from NED_Z_UNC)
    ('NED_Z_REF',         'Z_REF_NED',      None),
    ('NED_DIST',          'DIST_NED',       u.Mpc),
    # DIST_IVAR_NED inserted after DIST_NED in assembly (computed from NED_DIST_UNC)
    #('NED_TYPE',          'NED_TYPE',       None),
    ('NED_MORPH',         'MORPH',      None),
    ('NED_FLAG',          'NED_FLAG',       None),
    #('NED_SOURCE',        'NED_SOURCE',     None),
    #('BYNAME_SEP_ARCSEC', 'NED_BYNAME_SEP', u.arcsec),
]

# DESI columns added to the output: (name, numpy dtype, astropy unit)
DESI_COLS = [
    ('TARGETID_DESI',  np.int64,   None),
    ('SURVEY_DESI',    'U7',       None),
    ('PROGRAM_DESI',   'U6',       None),
    ('Z_DESI',         np.float64, None),
    ('Z_IVAR_DESI',     np.float64, None),
    ('ZWARN_DESI',     np.int64,   None),
    ('DELTACHI2_DESI', np.float64, None),
    ('SPECTYPE_DESI',  'U6',       None),
]

# Adopted redshift columns: (name, numpy dtype, astropy unit)
ADOPTED_COLS = [
    ('Z',      np.float64, None),
    ('Z_IVAR',  np.float64, None),
    ('Z_REF',  'U4',       None),
    ('Z_FLAG', np.int16,   None),
]

# Adopted distance columns; LVD takes precedence over NED when available.
DIST_COLS = [
    ('DIST',          np.float32, u.Mpc),
    ('DIST_IVAR',     np.float32, u.Mpc**-2),
    ('DIST_REF',      'U4',       None),
    ('DIST_LVD',      np.float32, u.Mpc),
    ('DIST_IVAR_LVD', np.float32, u.Mpc**-2),
]

# LVD redshift columns derived from vlos_systemic / vlos_sigma (km/s).
LVD_Z_COLS = [
    ('Z_LVD',      np.float64, None),
    ('Z_IVAR_LVD', np.float64, None),
]


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
def _detect_bands(beta):
    """Infer (optical) bands and all_bands from beta catalog column names."""
    bands     = [re.sub(r'^R26_', '', c)
                 for c in beta.colnames if re.match(r'^R26_[A-Z]+$', c)]
    all_bands = [re.sub(r'^COG_MTOT_', '', c)
                 for c in beta.colnames if re.match(r'^COG_MTOT_[A-Z0-9]+$', c)]
    return bands, all_bands


def _build_dm_ref(bands, all_bands):
    """1-row SGA_datamodel reference table for dtype/unit lookup (no data copy)."""
    dummy = Table({'SGAID': np.zeros(1, np.int64)})
    return SGA_datamodel(dummy, bands, all_bands, copy=False)


def _fix_dtypes(beta, dm):
    """Cast beta columns whose dtype does not match the SGA_datamodel reference.

    Byte-order differences (e.g. >f4 vs float32) are not considered mismatches;
    only kind (f/i/u/S/U) and itemsize are compared.
    """
    fixes = []
    for col in dm.colnames:
        if col not in beta.colnames:
            continue
        ref = dm[col].dtype
        cur = beta[col].dtype
        if cur.kind != ref.kind or cur.itemsize != ref.itemsize:
            beta[col] = beta[col].astype(ref)
            fixes.append((col, str(cur), str(ref)))
    return fixes


def _strval(v):
    """Return a stripped Python str, decoding bytes if necessary."""
    if isinstance(v, (bytes, np.bytes_)):
        return v.decode().strip()
    return str(v).strip()


def _str_arr_dtype(col):
    """Return a numpy Unicode dtype wide enough for the string column col."""
    dt = col.dtype
    if dt.kind == 'U':
        return dt
    if dt.kind == 'S':
        return f'U{dt.itemsize}'
    return 'U100'


def _angular_sep_arcsec(ra1, dec1, ra2, dec2):
    """Small-angle angular separation in arcsec; ra2/dec2 may be arrays."""
    cos_dec = np.cos(np.radians(dec1))
    return np.sqrt(((ra2 - ra1) * cos_dec)**2 + (dec2 - dec1)**2) * 3600.


def _select_desi(rows, sga_ra, sga_dec, max_sep_arcsec):
    """Select the best DESI spectrum for one SGA galaxy.

    rows          : numpy structured array — all match rows for this SGAID.
    sga_ra/dec    : SGA galaxy center (degrees).
    max_sep_arcsec: maximum allowed separation between SGA center and
                    DESI TARGET_RA/TARGET_DEC (excludes background objects).

    Returns the selected row (numpy.void) or None if no good spectrum exists.

    Note: target-bit logic (e.g. BGS_TARGET != 0) could be used to break
    ties before DELTACHI2, but is omitted because secondary-program
    observations are equally valid redshift sources.
    """
    # Step 0: proximity filter — only spectra near the SGA center
    seps = _angular_sep_arcsec(sga_ra, sga_dec,
                                rows['TARGET_RA'], rows['TARGET_DEC'])
    rows = rows[seps <= max_sep_arcsec]
    if len(rows) == 0:
        return None

    # Step 1: deduplicate repeat observations of the same TARGETID
    primary = rows[rows['ZCAT_PRIMARY'].astype(bool)]
    if len(primary) == 0:
        return None

    spectypes = np.array([_strval(s) for s in primary['SPECTYPE']])
    good      = primary['ZWARN'] == 0

    # Step 2: prefer GALAXY + ZWARN==0; fall back to any ZWARN==0
    pool = primary[(spectypes == 'GALAXY') & good]
    if len(pool) == 0:
        pool = primary[good]
    if len(pool) == 0:
        return None

    # Step 3: highest DELTACHI2
    return pool[np.argmax(pool['DELTACHI2'])]


def _reorder_cols(tbl):
    """Reorder tbl columns per COL_ORDER; append unlisted columns at the end."""
    unknown = [c for c in COL_ORDER if c not in tbl.colnames]
    if unknown:
        log.warning(f'COL_ORDER references unknown columns: {unknown}')
    listed    = [c for c in COL_ORDER if c in tbl.colnames]
    remaining = [c for c in tbl.colnames if c not in set(listed)]
    return tbl[listed + remaining]


# ---------------------------------------------------------------------------
# Per-region merge
# ---------------------------------------------------------------------------
def merge_region(region, neddir, redshiftdir, outdir, vdiff_threshold,
                 desi_max_sep, lvd_catalog=None):
    log.info(f'=== {region} ===')

    # --- SGA beta catalog -------------------------------------------------
    log.info('  Loading SGA beta catalog')
    _, beta = read_sga_sample(region=region)
    _, tractor = read_sga_sample(region=region, tractor=True)
    bands, all_bands = _detect_bands(beta)
    log.info(f'  Detected bands={bands}  all_bands={all_bands}')
    dm    = _build_dm_ref(bands, all_bands)
    fixes = _fix_dtypes(beta, dm)
    if fixes:
        for col, old, new in fixes:
            log.info(f'  dtype fix: {col}  {old} -> {new}')
    n = len(beta)
    log.info(f'  {n:,d} galaxies')

    # --- NED merged catalog -----------------------------------------------
    ned_path     = os.path.join(neddir, f'ned-merged-{region}.fits')
    log.info(f'  Loading {ned_path}')
    ned_tbl      = Table(fitsio.read(ned_path))
    ned_by_sgaid = {int(r['SGAID']): r for r in ned_tbl}

    # --- LVD catalog (distance takes precedence over NED for LVD objects) ---
    # Match by OBJNAME; distance and errors converted from kpc to Mpc.
    lvd_by_name = {}
    if lvd_catalog:
        log.info(f'  Loading LVD catalog {lvd_catalog}')
        lvd = Table.read(lvd_catalog)
        lvd_by_name = {str(r['name']): r for r in lvd}
        is_lvd      = (beta['SAMPLE'].value & SAMPLE_BITS['LVD']) != 0
        log.info(f'  LVD catalog: {len(lvd):,d} entries; '
                 f'{int(np.sum(is_lvd)):,d} LVD objects in SGA sample')

    # --- DESI summary (N_DESI per galaxy) ---------------------------------
    sum_path   = os.path.join(redshiftdir,
                              f'SGA2025-DESI-DR1-summary-{region}.fits')
    log.info(f'  Loading {sum_path}')
    summary    = fitsio.read(sum_path, columns=['SGAID', 'N_DESI'])
    ndesi_lookup = {int(r['SGAID']): int(r['N_DESI']) for r in summary}
    ndesi_arr  = np.array([ndesi_lookup.get(int(sid), 0)
                           for sid in beta['SGAID']], dtype=np.int32)

    # --- DESI matches (all spectra within SGA ellipses) -------------------
    match_path = os.path.join(redshiftdir,
                              f'SGA2025-DESI-DR1-matches-{region}.fits')
    log.info(f'  Loading {match_path}')
    matches    = fitsio.read(match_path)
    log.info(f'  {len(matches):,d} DESI match rows')

    grp = defaultdict(list)
    for i in range(len(matches)):
        grp[int(matches['SGAID'][i])].append(i)
    log.info(f'  {len(grp):,d} unique SGAIDs with DESI matches')

    # --- Pre-allocate output arrays ---------------------------------------
    # DESI: redshifts/IVARs sentinel 0., IDs sentinel -1, strings ''
    desi_arrs = {
        'TARGETID_DESI':  np.full(n, -1,           np.int64),
        'SURVEY_DESI':    np.full(n, '',            dtype='U7'),
        'PROGRAM_DESI':   np.full(n, '',            dtype='U6'),
        'Z_DESI':         np.zeros(n,               np.float64),
        'Z_IVAR_DESI':     np.zeros(n,               np.float64),
        'ZWARN_DESI':     np.full(n, -1,            np.int64),
        'DELTACHI2_DESI': np.full(n, FLOAT_SENTINEL, np.float64),
        'SPECTYPE_DESI':  np.full(n, '',            dtype='U6'),
    }

    # NED: columns with IVAR companions use 0. sentinel; others use FLOAT_SENTINEL
    ned_arrs = {}
    for src, dst, _ in NED_CARRY:
        if src not in ned_tbl.colnames:
            continue
        col = ned_tbl[src]
        if col.dtype.kind == 'f':
            sentinel = 0. if dst in NED_ZERO_SENTINEL else FLOAT_SENTINEL
            ned_arrs[dst] = np.full(n, sentinel, col.dtype)
        elif col.dtype.kind in ('i', 'u'):
            ned_arrs[dst] = np.zeros(n, col.dtype)
        else:
            ned_arrs[dst] = np.full(n, '', dtype=_str_arr_dtype(col))
    ned_arrs['Z_IVAR_NED']    = np.zeros(n, np.float64)  # from NED_Z_UNC
    ned_arrs['DIST_IVAR_NED'] = np.zeros(n, np.float32)  # from NED_DIST_UNC

    # Adopted redshift
    adopted_arrs = {
        'Z':      np.zeros(n, np.float64),
        'Z_IVAR':  np.zeros(n, np.float64),
        'Z_REF':  np.full(n, '', dtype='U4'),
        'Z_FLAG': np.zeros(n, np.int16),
    }

    # Adopted distance (LVD preferred over NED when available).
    # 0. sentinel — DIST_IVAR=0 signals no measurement.
    dist_arrs = {
        'DIST':          np.zeros(n, np.float32),
        'DIST_IVAR':     np.zeros(n, np.float32),
        'DIST_REF':      np.full(n, '', dtype='U4'),
        'DIST_LVD':      np.zeros(n, np.float32),
        'DIST_IVAR_LVD': np.zeros(n, np.float32),
    }

    # LVD redshifts (from vlos_systemic / vlos_sigma in km/s).
    lvd_z_arrs = {
        'Z_LVD':      np.zeros(n, np.float64),
        'Z_IVAR_LVD': np.zeros(n, np.float64),
    }

    # Convenient handles
    z_ned_arr     = ned_arrs.get('Z_NED')
    zivar_ned_arr = ned_arrs.get('Z_IVAR_NED')

    # --- Main resolution loop --------------------------------------------
    log.info(f'  Resolving redshifts (desi_max_sep={desi_max_sep:.1f}")')
    for i in range(n):
        sid     = int(beta['SGAID'][i])
        sga_ra  = float(beta['RA'][i])
        sga_dec = float(beta['DEC'][i])

        # DESI selection
        if sid in grp:
            best = _select_desi(matches[grp[sid]], sga_ra, sga_dec, desi_max_sep)
            if best is not None:
                zerr = float(best['ZERR'])
                desi_arrs['TARGETID_DESI'][i]  = int(best['TARGETID'])
                desi_arrs['SURVEY_DESI'][i]    = _strval(best['SURVEY'])
                desi_arrs['PROGRAM_DESI'][i]   = _strval(best['PROGRAM'])
                desi_arrs['Z_DESI'][i]         = float(best['Z'])
                desi_arrs['Z_IVAR_DESI'][i]     = 1. / zerr**2 if zerr > 0. else 0.
                desi_arrs['ZWARN_DESI'][i]     = int(best['ZWARN'])
                desi_arrs['DELTACHI2_DESI'][i] = float(best['DELTACHI2'])
                desi_arrs['SPECTYPE_DESI'][i]  = _strval(best['SPECTYPE'])

        # NED columns
        nrow = ned_by_sgaid.get(sid)
        if nrow is not None:
            for src, dst, _ in NED_CARRY:
                if dst not in ned_arrs:
                    continue
                val = nrow[src]
                arr = ned_arrs[dst]
                if arr.dtype.kind == 'f':
                    try:
                        fv = float(val)
                        arr[i] = fv if np.isfinite(fv) else (
                            0. if dst in NED_ZERO_SENTINEL else FLOAT_SENTINEL)
                    except (ValueError, TypeError):
                        pass  # sentinel already in place
                elif arr.dtype.kind in ('i', 'u'):
                    try:
                        arr[i] = int(val)
                    except (ValueError, TypeError):
                        pass
                else:
                    arr[i] = _strval(val)

            # Z_IVAR_NED: from NED_Z_UNC
            if 'NED_Z_UNC' in ned_tbl.colnames:
                try:
                    z_unc = float(nrow['NED_Z_UNC'])
                except (ValueError, TypeError):
                    z_unc = 0.
                z_ned_val = z_ned_arr[i] if z_ned_arr is not None else 0.
                if z_ned_val != 0. or z_unc > 0.:
                    err = z_unc if z_unc > 0. else NED_Z_NOMINAL_ERR
                    ned_arrs['Z_IVAR_NED'][i] = 1. / err**2

            # DIST_IVAR_NED: from NED_DIST_UNC; 0. if no error reported
            if 'NED_DIST_UNC' in ned_tbl.colnames:
                try:
                    dist_unc = float(nrow['NED_DIST_UNC'])
                except (ValueError, TypeError):
                    dist_unc = 0.
                dist_ned = ned_arrs['DIST_NED'][i]
                if dist_ned > 0. and dist_unc > 0.:
                    ned_arrs['DIST_IVAR_NED'][i] = np.float32(1. / dist_unc**2)

        # LVD redshifts and distances (matched by OBJNAME)
        objname = _strval(beta['OBJNAME'][i])
        if objname in lvd_by_name:
            lrow = lvd_by_name[objname]
            def _lvd_val(v):
                if np.ma.is_masked(v):
                    return float('nan')
                try:
                    return float(v)
                except (TypeError, ValueError):
                    return float('nan')
            # Z_LVD from vlos_systemic (km/s -> dimensionless z)
            vlos = _lvd_val(lrow['vlos_systemic'])
            em = _lvd_val(lrow['vlos_systemic_em'])
            ep = _lvd_val(lrow['vlos_systemic_ep'])
            if np.isfinite(vlos):
                lvd_z_arrs['Z_LVD'][i] = vlos / C_LIGHT
                mean_err = 0.5 * (em + ep)
                if np.isfinite(mean_err) and mean_err > 0.:
                    lvd_z_arrs['Z_IVAR_LVD'][i] = (C_LIGHT / mean_err)**2
            # DIST_LVD from distance (kpc -> Mpc)
            d_mpc = _lvd_val(lrow['distance']) / 1000.
            em    = _lvd_val(lrow['distance_em']) / 1000.
            ep    = _lvd_val(lrow['distance_ep']) / 1000.
            if np.isfinite(d_mpc) and d_mpc > 0.:
                dist_arrs['DIST_LVD'][i] = np.float32(d_mpc)
                mean_err = 0.5 * (em + ep)
                if np.isfinite(mean_err) and mean_err > 0.:
                    dist_arrs['DIST_IVAR_LVD'][i] = np.float32(1. / mean_err**2)

        # Adopted redshift: LVD > DESI > NED
        zivar_desi = desi_arrs['Z_IVAR_DESI'][i]
        z_desi     = desi_arrs['Z_DESI'][i]
        zivar_lvd  = lvd_z_arrs['Z_IVAR_LVD'][i]
        z_lvd      = lvd_z_arrs['Z_LVD'][i]
        zivar_ned  = zivar_ned_arr[i] if zivar_ned_arr is not None else 0.
        z_ned      = z_ned_arr[i]     if z_ned_arr     is not None else 0.

        if zivar_lvd > 0.:
            adopted_arrs['Z'][i]      = z_lvd
            adopted_arrs['Z_IVAR'][i] = zivar_lvd   # may be 0. if vlos_sigma missing
            adopted_arrs['Z_REF'][i]  = 'LVD'
        elif zivar_desi > 0.:
            adopted_arrs['Z'][i]      = z_desi
            adopted_arrs['Z_IVAR'][i] = zivar_desi
            adopted_arrs['Z_REF'][i]  = 'DESI'
        elif zivar_ned > 0.:
            adopted_arrs['Z'][i]      = z_ned
            adopted_arrs['Z_IVAR'][i] = zivar_ned
            adopted_arrs['Z_REF'][i]  = 'NED'

        # Z_FLAG: large velocity discrepancy between any two measured redshifts
        z_valid = []
        if z_lvd  != 0.:   z_valid.append(z_lvd)
        if zivar_desi > 0.: z_valid.append(z_desi)
        if zivar_ned  > 0.: z_valid.append(z_ned)
        for j in range(len(z_valid) - 1):
            for zb in z_valid[j + 1:]:
                if C_LIGHT * abs(z_valid[j] - zb) / (1. + min(z_valid[j], zb)) > vdiff_threshold:
                    adopted_arrs['Z_FLAG'][i] |= Z_FLAG_DISCREPANCY

        # Adopted distance: LVD preferred, then NED
        dist_ned      = ned_arrs['DIST_NED'][i]
        dist_ivar_ned = ned_arrs['DIST_IVAR_NED'][i]
        dist_lvd      = dist_arrs['DIST_LVD'][i]
        dist_ivar_lvd = dist_arrs['DIST_IVAR_LVD'][i]
        if dist_lvd > 0.:
            dist_arrs['DIST'][i]      = dist_lvd
            dist_arrs['DIST_IVAR'][i] = dist_ivar_lvd
            dist_arrs['DIST_REF'][i]  = 'LVD'
        elif dist_ned > 0.:
            dist_arrs['DIST'][i]      = dist_ned
            dist_arrs['DIST_IVAR'][i] = dist_ivar_ned   # may be 0. if no error
            dist_arrs['DIST_REF'][i]  = 'NED'

    # --- GALAXY and ALTNAMES from CROSSIDS --------------------------------
    crossids_col = ned_arrs.get('CROSSIDS')
    galaxy_arr   = np.full(n, '', dtype='U35')
    altnames_arr = np.full(n, '', dtype='U140')
    if crossids_col is not None:
        for i, crossids in enumerate(crossids_col):
            parts = [p.strip() for p in crossids.split('|') if p.strip()]
            if parts:
                galaxy_arr[i]   = parts[0]
                altnames_arr[i] = '|'.join(parts[1:3])

    # --- Assemble output Table -------------------------------------------
    out = beta.copy()

    # Propagate units from SGA_datamodel reference
    for col in dm.colnames:
        if col in out.colnames and dm[col].unit is not None:
            out[col].unit = dm[col].unit

    # New identification columns derived from NED CROSSIDS
    out.add_column(Column(galaxy_arr,   name='GALAXY'))
    out.add_column(Column(altnames_arr, name='ALTNAMES'))

    # DESI columns
    for name, dtype, unit in DESI_COLS:
        out.add_column(Column(desi_arrs[name], name=name, unit=unit))

    # NED columns: Z_IVAR_NED after Z_NED; DIST_IVAR_NED after DIST_NED
    for src, dst, unit in NED_CARRY:
        if dst not in ned_arrs:
            continue
        out.add_column(Column(ned_arrs[dst], name=dst, unit=unit))
        if dst == 'Z_NED':
            out.add_column(Column(ned_arrs['Z_IVAR_NED'],    name='Z_IVAR_NED'))
        elif dst == 'DIST_NED':
            out.add_column(Column(ned_arrs['DIST_IVAR_NED'], name='DIST_IVAR_NED',
                                  unit=u.Mpc**-2))

    # Adopted redshift
    for name, dtype, unit in ADOPTED_COLS:
        out.add_column(Column(adopted_arrs[name], name=name, unit=unit))

    # Adopted distance
    for name, dtype, unit in DIST_COLS:
        out.add_column(Column(dist_arrs[name], name=name, unit=unit))

    # LVD redshifts
    for name, dtype, unit in LVD_Z_COLS:
        out.add_column(Column(lvd_z_arrs[name], name=name, unit=unit))

    # Drop columns not wanted in the output
    for col in DROP_COLS:
        if col in out.colnames:
            out.remove_column(col)

    # Apply column ordering
    out = _reorder_cols(out)

    # --- Write output ----------------------------------------------------
    os.makedirs(outdir, exist_ok=True)
    outpath = os.path.join(outdir, f'SGA2025-{region}.fits')
    vals, names, units = table_to_fitsio(out)
    tractor_vals, tractor_names, tractor_units = table_to_fitsio(tractor)
    with fitsio.FITS(outpath, 'rw', clobber=True) as F:
        F.write(vals, names=names, units=units, extname='SGA2025')
        F.write(tractor_vals, names=tractor_names, units=tractor_units, extname='TRACTOR')
    log.info(f'  Wrote {outpath}')

    # --- Summary statistics (stdout) -------------------------------------
    pct        = lambda k: 100. * k / n if n else 0.
    src_arr    = adopted_arrs['Z_REF']
    flag_arr   = adopted_arrs['Z_FLAG']

    n_src_desi  = int(np.sum(src_arr == 'DESI'))
    n_src_lvd   = int(np.sum(src_arr == 'LVD'))
    n_src_ned   = int(np.sum(src_arr == 'NED'))
    n_src_none  = int(np.sum(src_arr == ''))
    n_disc      = int(np.sum((flag_arr & Z_FLAG_DISCREPANCY) != 0))
    n_desi_prox = int(np.sum((ndesi_arr > 0) & (desi_arrs['Z_IVAR_DESI'] == 0.)))
    n_z_lvd      = int(np.sum(lvd_z_arrs['Z_LVD'] != 0.))
    n_z_lvd_ivar = int(np.sum(lvd_z_arrs['Z_IVAR_LVD'] > 0.))

    n_dist_ned  = int(np.sum(ned_arrs['DIST_NED'] > 0.))
    n_dist_ivar = int(np.sum(ned_arrs['DIST_IVAR_NED'] > 0.))
    n_dist_lvd  = int(np.sum(dist_arrs['DIST_LVD'] > 0.))
    n_dist_ivar_lvd = int(np.sum(dist_arrs['DIST_IVAR_LVD'] > 0.))
    n_dist_adopted  = int(np.sum(dist_arrs['DIST'] > 0.))
    n_dist_ref_lvd  = int(np.sum(np.array(dist_arrs['DIST_REF']) == 'LVD'))
    n_dist_ref_ned  = int(np.sum(np.array(dist_arrs['DIST_REF']) == 'NED'))

    print(f'\n--- {region} summary ({n:,d} galaxies) ---')
    print(f'  desi_max_sep={desi_max_sep:.1f}"  vdiff_threshold={vdiff_threshold:.0f} km/s')
    if fixes:
        print('  Dtype fixes: ' +
              ', '.join(f'{c}: {o} -> {nw}' for c, o, nw in fixes))
    print()
    print(f'  Z_REF = DESI : {n_src_desi:>8,d}  ({pct(n_src_desi):5.1f}%)')
    print(f'  Z_REF = LVD  : {n_src_lvd:>8,d}  ({pct(n_src_lvd):5.1f}%)')
    print(f'  Z_REF = NED  : {n_src_ned:>8,d}  ({pct(n_src_ned):5.1f}%)')
    print(f'  Z_REF = none : {n_src_none:>8,d}  ({pct(n_src_none):5.1f}%)')
    print()
    print(f'  Z_LVD present (vlos_systemic): {n_z_lvd:>8,d}  ({pct(n_z_lvd):5.1f}%)')
    print(f'  Z_LVD with IVAR (vlos_sigma) : {n_z_lvd_ivar:>8,d}  ({pct(n_z_lvd_ivar):5.1f}%)')
    print()
    print(f'  Z_FLAG discrepancy           : {n_disc:>8,d}  ({pct(n_disc):5.1f}%)')
    print(f'  N_DESI>0, no good central z  : {n_desi_prox:>8,d}  ({pct(n_desi_prox):5.1f}%)')
    print()
    print(f'  DIST_NED present             : {n_dist_ned:>8,d}  ({pct(n_dist_ned):5.1f}%)')
    print(f'  DIST_NED with IVAR           : {n_dist_ivar:>8,d}  ({pct(n_dist_ivar):5.1f}%)')
    print(f'  DIST_LVD present             : {n_dist_lvd:>8,d}  ({pct(n_dist_lvd):5.1f}%)')
    print(f'  DIST_LVD with IVAR           : {n_dist_ivar_lvd:>8,d}  ({pct(n_dist_ivar_lvd):5.1f}%)')
    print(f'  Adopted DIST present         : {n_dist_adopted:>8,d}  ({pct(n_dist_adopted):5.1f}%)')
    print(f'    DIST_REF = LVD             : {n_dist_ref_lvd:>8,d}')
    print(f'    DIST_REF = NED             : {n_dist_ref_ned:>8,d}')
    print()
    print('  N_DESI distribution:')
    for label, mask in [
            ('= 0',    ndesi_arr == 0),
            ('= 1',    ndesi_arr == 1),
            ('2-9',   (ndesi_arr >= 2)   & (ndesi_arr <= 9)),
            ('10-99', (ndesi_arr >= 10)  & (ndesi_arr <= 99)),
            ('>= 100', ndesi_arr >= 100)]:
        k = int(np.sum(mask))
        print(f'    {label:>6} : {k:>8,d}  ({pct(k):5.1f}%)')


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument('--neddir', required=True,
                        help='Directory containing ned-merged-{region}.fits')
    parser.add_argument('--redshiftdir', required=True,
                        help='Directory containing DESI DR1 summary and matches files')
    parser.add_argument('--outdir', required=True,
                        help='Output directory for SGA2025-{region}.fits')
    parser.add_argument('--region', choices=['dr11-south', 'dr11-north'],
                        help='Process one region only (default: both)')
    parser.add_argument('--vdiff-threshold', type=float, default=1000.,
                        help='DESI/NED velocity discrepancy threshold in km/s '
                             '(default: 1000)')
    parser.add_argument('--desi-max-sep', type=float, default=3.,
                        help='Max separation between SGA center and DESI '
                             'TARGET_RA/DEC in arcsec (default: 3)')
    parser.add_argument('--lvd-catalog',
                        help='Path to LVD ECSV catalog (e.g. lvd_comb_all_v1.1.0.ecsv); '
                             'distances in kpc converted to Mpc')
    args = parser.parse_args()

    regions = [args.region] if args.region else ['dr11-south', 'dr11-north']
    for region in regions:
        merge_region(region, args.neddir, args.redshiftdir, args.outdir,
                     args.vdiff_threshold, args.desi_max_sep,
                     lvd_catalog=args.lvd_catalog)


if __name__ == '__main__':
    main()

NED_Z_NOMINAL_ERR     = 100. / C_LIGHT  # assumed ZERR when NED_Z_UNC == 0 (=100 km/s)
FLOAT_SENTINEL        = -1.              # sentinel for floats without an IVAR companion
Z_FLAG_DISCREPANCY       = 0x01          # |Delta cz (DESI, NED)| > vdiff_threshold
Z_FLAG_NED_SUSPECT       = 0x02          # sole measurement is NED; NED_FLAG Z_SUSPECT set
Z_FLAG_NED_UNRESOLVED    = 0x04          # sole measurement is NED; NED_FLAG Z_UNRESOLVED set
Z_FLAG_NED_MISSING       = 0x08          # sole measurement is NED; NED_FLAG Z_MISSING set
Z_FLAG_CONSENSUS_OVERRIDE = 0x10         # DESI disagreed with an agreeing SDSS/NED pair; replaced by SDSS
Z_FLAG_AUTO_NED_OVERRIDE = 0x20          # adopted DESI/SDSS Z > --ned-override-zmin replaced by NED
Z_FLAG_VI_REVIEWED       = 0x40          # Z/Z_IVAR/Z_REF set or confirmed by --vi-redshifts; last
                                          # bit by convention -- the final, human-authoritative step

# Must match FLAG_Z_SUSPECT / FLAG_Z_UNRESOLVED / FLAG_Z_MISSING in SGA2025-ned-merge.
NED_FLAG_Z_SUSPECT    = 0x08
NED_FLAG_Z_UNRESOLVED = 0x10
NED_FLAG_Z_MISSING    = 0x20

# CMB dipole apex (Planck 2018), used to convert the adopted (heliocentric) Z
# to a CMB-frame redshift before querying pvhub -- pvhub's reconstructions
# (and their 2M++ coverage boundary) are defined in the CMB frame.
CMB_APEX_RA_DEG     = 167.942
CMB_APEX_DEC_DEG    = -6.944
CMB_APEX_V_KMS      = 369.82
# Objects at or beyond this CMB-frame velocity are outside/at the edge of the
# pvhub reconstructions' domain; Z_COSMO falls back to the CMB-frame redshift
# with no peculiar-velocity correction (Z_COSMO_IVAR carried over from Z_IVAR).
PVHUB_VCMB_MAX_KMS  = 20000.

# NED_CARRY output columns that use 0. as their missing sentinel because they
# have an IVAR companion column (IVAR=0 signals no measurement).
NED_ZERO_SENTINEL = frozenset({'Z_NED', 'DIST_NED'})


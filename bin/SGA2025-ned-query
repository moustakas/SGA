#!/usr/bin/env python
"""
ned-crossids: Query the NED API for cross-IDs and basic data for SGA-2025 galaxies.

Three query types (--querytype):

  overview (default): OverviewOfObject fiducial data for every galaxy in the
    full SGA sample, one row per galaxy. Target resolution has two modes:

      --bypos (default): ConeSearchByPosition finds the nearest NED object
        within --radius arcsec (default 5), then OverviewOfObject retrieves
        all basic data including cross-IDs.  Output: ned-bypos-{region}.csv

      --byname: OverviewOfObject queried directly by SGA OBJNAME. Useful for
        galaxies that fail the positional match due to coordinate offsets.
        Output: ned-byname-{region}.csv

  redshifts / distances: RedshiftsOfObject / DistancesOfObject for every
    galaxy with a successful NED match, queried directly by NED_NAME. This
    has no column/threshold gate, so it also catches objects OverviewOfObject
    never assigned a fiducial NED_Z/NED_DIST to at all but which still have
    real measurements in NED's full list (e.g. UGC 06451). Requires
    ned-merged-{region}.fits in --outdir (see SGA2025-ned-merge); the target
    name for each SGAID is that object's own winning CROSSIDS[0] (already
    arbitrated between byname/bypos by ned-merge), not derived directly from
    ned-byname/ned-bypos -- bypos's raw NED_NAME can point to a different,
    poorly cross-identified NED entry near the SGA position and return zero
    rows. Unlike overview, NED returns *all* available measurements per
    object (not just the fiducial one), so the output has one row per
    measurement, not per galaxy. Output: ned-{querytype}-{region}.csv

    NED's name resolution isn't always symmetric: a winning CROSSIDS[0]
    name can fail against RedshiftsOfObject/DistancesOfObject even though
    the originally-submitted byname OBJNAME resolves fine for the same
    object (e.g. 'SDSS 587739302613680312' fails, 'SDSS
    J133845.98+323042.0' succeeds). When the CROSSIDS[0] query comes back
    empty, it is retried once more using OBJNAME, if that object's byname
    query itself succeeded.

Safe to restart: SGAIDs already present in the output file are skipped.

Hiccup protection: NED VOTable responses declare their row count in a
RECORDS_RETURNED parameter. If NED declares N > 0 rows but delivers 0, the
response is flagged ERROR='hiccup' and the query is retried once automatically.
If the overview step succeeds in finding a NED name but returns no data, it is
flagged ERROR='overview_failed' rather than being silently empty. This is
separate from the OBJNAME fallback above, which retries with a different
query target rather than the same one.

Throughput with default settings (--maxconcurrent 10, --delay 0.1):
  ~8 NED requests/s -> ~4 gal/s (bypos, 2 calls each) or ~8 gal/s (byname,
  redshifts, distances). Run dr11-north and dr11-south in parallel on
  separate nodes.

Examples
--------
# Test on the first 20 objects:
ned-crossids --region dr11-south --outdir /tmp/ned-test --ntest 20
ned-crossids --region dr11-south --outdir /tmp/ned-test --ntest 20 --byname

# Full runs, one region at a time:
ned-crossids --region dr11-south --outdir /path/to/output
ned-crossids --region dr11-south --outdir /path/to/output --byname
ned-crossids --region dr11-north --outdir /path/to/output

# Redshifts/distances for the full sample (after the overview runs above
# and SGA2025-ned-merge --outdir /path/to/output):
ned-crossids --querytype redshifts  --region dr11-south --outdir /path/to/output
ned-crossids --querytype distances  --region dr11-south --outdir /path/to/output

"""
import os
import re
import csv
import time
import asyncio
import argparse
import numpy as np
from io import BytesIO

import aiohttp
import fitsio
from astropy.table import Table
from astropy.io.votable import parse_single_table

from SGA.SGA import read_sga_sample, SAMPLE as SAMPLE_BITS
from SGA.external import nedfriendly_lvd
from SGA.logger import log

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
NED_BASE   = 'https://ned.ipac.caltech.edu/NED::API'
USER_AGENT = 'SGA-NED-crossid/1.0 (jmoustakas@siena.edu)'

# OverviewOfObject VOTable FIELD ID -> output CSV column name.
# Excluded at user request: v_Sun, unc_v_Sun, v_Sun_3K, unc_v_Sun_3K,
# d_Sun_3K, unc_d_Sun_3K, a_lambda_V, a_lambda_K, gal_lon, gal_lat.
OVERVIEW_COL_MAP = {
    'enotes':           'NED_NOTES',
    'equ_j2000_lon_s':  'NED_RA_S',
    'equ_j2000_lat_s':  'NED_DEC_S',
    'equ_j2000_lon':    'NED_RA',
    'equ_j2000_lat':    'NED_DEC',
    'unc_sma':          'NED_POS_UNC_SMA',
    'unc_smi':          'NED_POS_UNC_SMI',
    'equ_j2000_unc_pa': 'NED_POS_UNC_PA',
    'pos_reference':    'NED_POS_REF',
    'z':                'NED_Z',
    'unc_z':            'NED_Z_UNC',
    'z_refcode':        'NED_Z_REF',
    'mean_distance':    'NED_DIST',
    'SEM_distance':     'NED_DIST_UNC',
    'emregion':         'NED_EMREGION',
    'pretype':          'NED_TYPE',
    'o_class_morph':    'NED_MORPH',
    'morph_refcode':    'NED_MORPH_REF',
    'o_class_activity': 'NED_ACTIVITY',
    'activity_refcode': 'NED_ACTIVITY_REF',
    'o_class_other':    'NED_OTHER',
    'o_diam_passband':  'NED_DIAM_BAND',
    'o_diam_maj_dia':   'NED_DIAM',
    'diameter_refcode': 'NED_DIAM_REF',
    'diameter_kpc':     'NED_DIAM_KPC',
    'o_footnote':       'NED_FOOTNOTE',
}

OVERVIEW_FIELDS = ['CROSSIDS', 'N_CROSSIDS'] + list(OVERVIEW_COL_MAP.values())
BYPOS_FIELDS    = ['SGAID', 'NED_NAME', 'SEPARATION_ARCSEC', 'NMATCHES'] + OVERVIEW_FIELDS + ['ERROR']
BYNAME_FIELDS   = ['SGAID', 'OBJNAME'] + OVERVIEW_FIELDS + ['ERROR']

# RedshiftsOfObject / DistancesOfObject VOTable FIELD ID -> output CSV column
# name. Unlike OverviewOfObject these return all available measurements per
# object (not just the fiducial one), so output is one row per measurement.
REDSHIFT_COL_MAP = {
    'row':           'ROW',
    'z':             'NED_Z',
    'unc_z':         'NED_Z_UNC',
    'velocity':      'NED_CZ',
    'velocity_unc':  'NED_CZ_UNC',
    'z_technique':   'NED_Z_TECHNIQUE',
    'z_method':      'NED_Z_METHOD',
    'quality_flag':  'NED_Z_QUALITY',
    'bandpass':      'NED_Z_BANDPASS',
    'reference':     'NED_Z_REF',
    'fiducial':      'NED_Z_FIDUCIAL',
}
DISTANCE_COL_MAP = {
    'row':           'ROW',
    'dist_mod':      'NED_DISTMOD',
    'dist_mod_err':  'NED_DISTMOD_UNC',
    'distance':      'NED_DIST',
    'method':        'NED_DIST_METHOD',
    'refcode':       'NED_DIST_REF',
    'notes':         'NED_DIST_NOTES',
    'SN_name':       'NED_DIST_SNNAME',
    'def_redshift':  'NED_DIST_Z',
    'def_H0':        'NED_DIST_H0',
    'def_LMC_mod':   'NED_DIST_LMCMOD',
}
REDSHIFTS_FIELDS = ['SGAID', 'NED_NAME'] + list(REDSHIFT_COL_MAP.values()) + ['ERROR']
DISTANCES_FIELDS = ['SGAID', 'NED_NAME'] + list(DISTANCE_COL_MAP.values()) + ['ERROR']

MULTI_ENDPOINTS = {
    'redshifts': ('RedshiftsOfObject', REDSHIFT_COL_MAP, REDSHIFTS_FIELDS),
    'distances': ('DistancesOfObject', DISTANCE_COL_MAP, DISTANCES_FIELDS),
}

_REC_RE = re.compile(rb'name="RECORDS_RETURNED"[^>]+value="(\d+)"')


# ---------------------------------------------------------------------------
# VOTable parsing helpers
# ---------------------------------------------------------------------------
def _records_returned(content):
    """Extract the declared RECORDS_RETURNED count from raw VOTable bytes.

    NED always includes this PARAM in its responses. If it is missing (e.g.
    on an error page), returns None.
    """
    m = _REC_RE.search(content)
    return int(m.group(1)) if m else None


def _parse_votable(content):
    """Parse VOTable bytes; return astropy Table or None on any error."""
    if not content:
        return None
    try:
        return parse_single_table(BytesIO(content)).to_table()
    except Exception:
        return None


def _col(table, *candidates):
    """Return the first candidate column name that exists in table."""
    for name in candidates:
        if name in table.colnames:
            return name
    return None


def _scalar(row, col):
    """Extract a scalar value from a table row; return '' for masked entries."""
    if col is None:
        return ''
    v = row[col]
    if hasattr(v, 'mask') and np.ndim(v.mask) == 0 and v.mask:
        return ''
    return v


def parse_cone_search(content, sga_id):
    """Parse ConeSearchByPosition response.

    Returns a dict with SGAID, NED_NAME, SEPARATION_ARCSEC, NMATCHES, ERROR.
    ERROR='hiccup' means NED declared rows but delivered none.
    """
    base = {'SGAID': sga_id, 'NED_NAME': '', 'SEPARATION_ARCSEC': '',
            'NMATCHES': 0, 'ERROR': ''}

    table = _parse_votable(content)
    if table is None:
        base['ERROR'] = 'parse_error'
        return base
    if len(table) == 0:
        ndecl = _records_returned(content)
        base['ERROR'] = 'hiccup' if (ndecl is not None and ndecl > 0) else 'no_match'
        return base

    row      = table[0]   # NED returns rows sorted by separation ascending
    name_col = _col(table, 'prefname', 'Object Name', 'objname')
    sep_col  = _col(table, 'sep', 'Separation', 'separation')

    if name_col is None:
        base['ERROR'] = f'col_mismatch: {table.colnames}'
        return base

    sep_raw    = _scalar(row, sep_col)
    sep_arcsec = f'{float(sep_raw) * 60.0:.3f}' if sep_raw != '' else ''

    base.update({
        'NED_NAME':          str(_scalar(row, name_col)).strip(),
        'SEPARATION_ARCSEC': sep_arcsec,
        'NMATCHES':          len(table),
    })
    return base


def parse_overview(content):
    """Parse OverviewOfObject response.

    Returns (data_dict, error_str).  error_str is '' on success, 'hiccup' if
    NED declared rows but delivered none, 'no_match' for a genuine empty
    result, or 'parse_error' on a malformed response.
    """
    table = _parse_votable(content)
    if table is None:
        return {}, 'parse_error'
    if len(table) == 0:
        ndecl = _records_returned(content)
        err   = 'hiccup' if (ndecl is not None and ndecl > 0) else 'no_match'
        return {}, err

    row    = table[0]
    result = {}

    # CrossID_list is a semicolon-delimited string; store pipe-delimited + count.
    id_col   = _col(table, 'CrossID_list')
    raw      = _scalar(row, id_col) if id_col else ''
    crossids = [s.strip() for s in str(raw).split(';') if s.strip()] if raw else []
    result['CROSSIDS']   = '|'.join(crossids)
    result['N_CROSSIDS'] = len(crossids)

    for vtid, csvname in OVERVIEW_COL_MAP.items():
        col = _col(table, vtid)
        result[csvname] = _scalar(row, col) if col else ''

    return result, ''


def parse_multi(content, col_map):
    """Parse a RedshiftsOfObject/DistancesOfObject response.

    Unlike OverviewOfObject, these return all available measurements per
    object rather than a single fiducial row. Returns (rows, error_str):
    rows is a list of dicts (one per measurement, possibly empty), error_str
    is '' on success, 'hiccup' if NED declared rows but delivered none,
    'no_match' for a genuine empty result, or 'parse_error' on a malformed
    response.
    """
    table = _parse_votable(content)
    if table is None:
        return [], 'parse_error'
    if len(table) == 0:
        ndecl = _records_returned(content)
        err   = 'hiccup' if (ndecl is not None and ndecl > 0) else 'no_match'
        return [], err

    rows = []
    for row in table:
        entry = {}
        for vtid, csvname in col_map.items():
            col = _col(table, vtid)
            entry[csvname] = _scalar(row, col) if col else ''
        rows.append(entry)
    return rows, ''


# ---------------------------------------------------------------------------
# Async fetch and per-galaxy processing
# ---------------------------------------------------------------------------
async def _fetch(session, url, params, semaphore, delay, retries=3):
    """Rate-limited GET with retries. Returns response bytes or b'' on failure."""
    async with semaphore:
        content = b''
        for attempt in range(retries):
            try:
                async with session.get(url, params=params,
                                       timeout=aiohttp.ClientTimeout(total=30)) as resp:
                    if resp.status == 200:
                        content = await resp.read()
                        break
                    if resp.status == 429:          # Too Many Requests
                        await asyncio.sleep(60.0)   # back off hard, then retry
                    else:
                        break                       # non-retryable HTTP error
            except Exception as exc:
                if attempt == retries - 1:
                    log.warning(f'Fetch failed ({url} {params}): {exc}')
                else:
                    await asyncio.sleep(2.0 ** attempt)
        await asyncio.sleep(delay)
    return content


async def _process_bypos(session, sga_id, ra, dec, semaphore, delay, radius_arcmin):
    """ConeSearch then OverviewOfObject for one galaxy, with hiccup retries."""
    params1 = {
        'LON':     f'{ra:.6f}d',
        'LAT':     f'{dec:.6f}d',
        'RADIUS':  f'{radius_arcmin:.6f}',
        'CSYS':    'Equatorial',
        'EQUINOX': 'J2000.0',
    }

    # Retry cone search once on hiccup.
    result = {}
    for _ in range(2):
        content1 = await _fetch(session, f'{NED_BASE}/ConeSearchByPosition',
                                params1, semaphore, delay)
        result = parse_cone_search(content1, sga_id)
        if result['ERROR'] != 'hiccup':
            break

    # Retry overview once on hiccup; flag explicitly if it still fails.
    if result['NED_NAME']:
        overview, ov_err = {}, 'hiccup'
        for _ in range(2):
            content2 = await _fetch(session, f'{NED_BASE}/OverviewOfObject',
                                    {'TARGET': result['NED_NAME']}, semaphore, delay)
            overview, ov_err = parse_overview(content2)
            if ov_err != 'hiccup':
                break
        if overview:
            result.update(overview)
        elif not result['ERROR']:
            result['ERROR'] = ov_err if ov_err else 'overview_failed'

    return {k: result.get(k, '') for k in BYPOS_FIELDS}


async def _process_byname(session, sga_id, objname, ned_target, semaphore, delay):
    """OverviewOfObject queried by ned_target; OBJNAME stores the original SGA name."""
    result = {'SGAID': sga_id, 'OBJNAME': objname, 'ERROR': ''}

    overview, ov_err = {}, 'hiccup'
    for _ in range(2):
        content = await _fetch(session, f'{NED_BASE}/OverviewOfObject',
                               {'TARGET': ned_target}, semaphore, delay)
        overview, ov_err = parse_overview(content)
        if ov_err != 'hiccup':
            break

    if overview:
        result.update(overview)
    else:
        result['ERROR'] = ov_err if ov_err else 'no_match'

    return {k: result.get(k, '') for k in BYNAME_FIELDS}


async def _process_multi(session, sga_id, ned_name, endpoint, col_map, fields,
                         semaphore, delay, fallback_name=''):
    """RedshiftsOfObject/DistancesOfObject for one galaxy, with hiccup retries.

    If the primary ned_name query comes back empty (any error), and
    fallback_name (the object's byname-submitted OBJNAME) is given and
    differs from ned_name, retries once more with fallback_name -- NED's
    name resolution isn't always symmetric, and the winning CROSSIDS[0]
    name occasionally fails here even though OBJNAME resolves fine for the
    same object.

    Always returns at least one row (so checkpoint/resume can mark the SGAID
    done even when NED has no measurements or the query fails).
    """
    async def _attempt(target):
        rows, err = [], 'hiccup'
        for _ in range(2):
            content = await _fetch(session, f'{NED_BASE}/{endpoint}',
                                   {'TARGET': target}, semaphore, delay)
            rows, err = parse_multi(content, col_map)
            if err != 'hiccup':
                break
        return rows, err

    used_name = ned_name
    rows, err = await _attempt(ned_name)
    if not rows and fallback_name and fallback_name != ned_name:
        fb_rows, fb_err = await _attempt(fallback_name)
        if fb_rows:
            rows, err, used_name = fb_rows, fb_err, fallback_name

    if not rows:
        return [{k: '' for k in fields} |
                {'SGAID': sga_id, 'NED_NAME': used_name, 'ERROR': err}]

    results = []
    for row in rows:
        row.update({'SGAID': sga_id, 'NED_NAME': used_name, 'ERROR': ''})
        results.append({k: row.get(k, '') for k in fields})
    return results


async def _run_chunk(ids, data, outfile, fields, maxconcurrent, delay, byname, radius_arcmin,
                     ned_targets=None):
    """Process one chunk of galaxies and append results to outfile."""
    semaphore = asyncio.Semaphore(maxconcurrent)
    async with aiohttp.ClientSession(headers={'User-Agent': USER_AGENT}) as session:
        if byname:
            targets = ned_targets if ned_targets is not None else data
            tasks = [_process_byname(session, int(sid), name, str(tgt), semaphore, delay)
                     for sid, name, tgt in zip(ids, data, targets)]
        else:
            tasks = [_process_bypos(session, int(sid), float(ra), float(dec),
                                    semaphore, delay, radius_arcmin)
                     for sid, (ra, dec) in zip(ids, data)]
        results = await asyncio.gather(*tasks)

    write_header = not os.path.exists(outfile) or os.path.getsize(outfile) == 0
    with open(outfile, 'a', newline='') as f:
        writer = csv.DictWriter(f, fieldnames=fields)
        if write_header:
            writer.writeheader()
        writer.writerows(results)

    return results


async def _run_chunk_multi(ids, ned_names, outfile, fields, maxconcurrent, delay,
                           endpoint, col_map, fallback_names=None):
    """Process one chunk of galaxies (redshifts/distances) and append to outfile.

    Each task can return multiple rows (one per measurement), so results are
    flattened before writing.
    """
    if fallback_names is None:
        fallback_names = [''] * len(ids)
    semaphore = asyncio.Semaphore(maxconcurrent)
    async with aiohttp.ClientSession(headers={'User-Agent': USER_AGENT}) as session:
        tasks = [_process_multi(session, int(sid), str(name), endpoint, col_map, fields,
                                semaphore, delay, fallback_name=str(fbname))
                 for sid, name, fbname in zip(ids, ned_names, fallback_names)]
        nested = await asyncio.gather(*tasks)
    results = [row for rows in nested for row in rows]

    write_header = not os.path.exists(outfile) or os.path.getsize(outfile) == 0
    with open(outfile, 'a', newline='') as f:
        writer = csv.DictWriter(f, fieldnames=fields)
        if write_header:
            writer.writeheader()
        writer.writerows(results)

    return nested


# ---------------------------------------------------------------------------
# Checkpoint / restart
# ---------------------------------------------------------------------------
def _load_done(outfile):
    """Return the set of SGAIDs already present in outfile."""
    done = set()
    if not os.path.exists(outfile):
        return done
    with open(outfile, newline='') as f:
        for row in csv.DictReader(f):
            try:
                done.add(int(row['SGAID']))
            except (KeyError, ValueError):
                pass
    return done


# ---------------------------------------------------------------------------
# Full-sample NED_NAME resolution for redshifts/distances querytypes
# ---------------------------------------------------------------------------
def load_fullsample_targets(ned_merged_path):
    """Resolve SGAID -> NED target name for every galaxy with a successful
    NED cross-match, from the already-arbitrated ned-merged-{region}.fits
    (see SGA2025-ned-merge).

    Uses the *winning* source's own CROSSIDS[0] as the query target
    (guaranteed to round-trip back to the same NED object, since it came
    from that object's own cross-ID list), falling back to the bypos-only
    NED_NAME column when CROSSIDS is empty (NED_SOURCE='none' -- no
    successful match at all).

    Do not resolve names from ned-byname/ned-bypos directly: bypos's
    NED_NAME sometimes points to a different, poorly cross-identified NED
    entry near the SGA position (e.g. a lone WISE detection) rather than the
    richly-cross-identified object byname found for the same SGAID --
    confirmed to return zero RedshiftsOfObject/DistancesOfObject rows in
    that case (e.g. UGC 06451 / SGAID 5054374).

    Also returns `fallback_targets`: dict[SGAID -> OBJNAME] for objects
    where the byname query itself succeeded (NED_ERROR_BYNAME == ''). NED's
    name resolution isn't always symmetric -- a winning CROSSIDS[0] target
    can fail in RedshiftsOfObject/DistancesOfObject even though the
    originally-submitted OBJNAME resolves fine for the same object (e.g.
    'SDSS 587739302613680312' fails, 'SDSS J133845.98+323042.0' succeeds).
    Used by run_multi as a per-object retry target when the primary lookup
    comes back empty.
    """
    tbl = Table(fitsio.read(ned_merged_path,
                columns=['SGAID', 'CROSSIDS', 'NED_NAME', 'OBJNAME', 'NED_ERROR_BYNAME']))
    targets  = {}
    fallback = {}
    for row in tbl:
        sid      = int(row['SGAID'])
        crossids = str(row['CROSSIDS']).strip()
        name     = crossids.split('|')[0].strip() if crossids else str(row['NED_NAME']).strip()
        if name:
            targets[sid] = name
        if str(row['NED_ERROR_BYNAME']) == '':
            objname = str(row['OBJNAME']).strip()
            if objname:
                fallback[sid] = objname
    return targets, fallback


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
def run_multi(args):
    """Run RedshiftsOfObject/DistancesOfObject for the full SGA sample."""
    os.makedirs(args.outdir, exist_ok=True)
    endpoint, col_map, fields = MULTI_ENDPOINTS[args.querytype]
    outfile         = os.path.join(args.outdir, f'ned-{args.querytype}-{args.region}.csv')
    ned_merged_path = os.path.join(args.outdir, f'ned-merged-{args.region}.fits')

    if not os.path.exists(ned_merged_path):
        raise SystemExit(f'{ned_merged_path} does not exist; run SGA2025-ned-merge first.')

    log.info(f'Resolving NED targets from {ned_merged_path}')
    targets, fallback_targets = load_fullsample_targets(ned_merged_path)
    sgaid    = np.array(sorted(targets.keys()))
    ned_name = np.array([targets[s] for s in sgaid])
    fallback_name = np.array([fallback_targets.get(s, '') for s in sgaid])
    log.info(f'  {len(sgaid):,d} NED-matched objects')

    if args.ntest > 0:
        log.info(f'Test mode: {args.ntest} objects')
        sgaid         = sgaid[:args.ntest]
        ned_name      = ned_name[:args.ntest]
        fallback_name = fallback_name[:args.ntest]

    done = _load_done(outfile)
    if done:
        log.info(f'Resuming: {len(done)} SGAIDs already done, skipping')
    mask          = np.array([int(s) not in done for s in sgaid])
    sgaid         = sgaid[mask]
    ned_name      = ned_name[mask]
    fallback_name = fallback_name[mask]

    ntotal  = len(sgaid)
    nchunks = int(np.ceil(ntotal / args.chunksize))
    log.info(f'Mode: {args.querytype} ({endpoint}) | {ntotal} galaxies | '
             f'{nchunks} chunks -> {outfile}')
    log.info(f'maxconcurrent={args.maxconcurrent}, delay={args.delay}s')

    t0    = time.time()
    ndone = 0
    for ichunk in range(nchunks):
        sl = slice(ichunk * args.chunksize, (ichunk + 1) * args.chunksize)
        nested = asyncio.run(
            _run_chunk_multi(sgaid[sl], ned_name[sl], outfile, fields,
                             args.maxconcurrent, args.delay, endpoint, col_map,
                             fallback_names=fallback_name[sl])
        )
        ndone   += len(nested)
        elapsed  = time.time() - t0
        rate     = ndone / elapsed
        eta_hr   = (ntotal - ndone) / rate / 3600 if rate > 0 else 0
        nmatch   = sum(1 for rows in nested if rows and not rows[0].get('ERROR'))
        nerror   = sum(1 for rows in nested if rows and rows[0].get('ERROR'))
        nrows    = sum(len(rows) for rows in nested)
        log.info(
            f'Chunk {ichunk+1}/{nchunks}: {len(nested)} galaxies ({nrows} rows), '
            f'{nmatch} matched, {nerror} errors | '
            f'{rate:.2f} gal/s, ETA {eta_hr:.1f} hr'
        )

    log.info(f'Finished. Total elapsed: {(time.time() - t0) / 3600:.2f} hr')


def run_overview(args):
    """Run the OverviewOfObject query (bypos or byname) for the full SGA sample."""
    os.makedirs(args.outdir, exist_ok=True)
    mode          = 'byname' if args.byname else 'bypos'
    outfile       = os.path.join(args.outdir, f'ned-{mode}-{args.region}.csv')
    fields        = BYNAME_FIELDS if args.byname else BYPOS_FIELDS
    radius_arcmin = args.radius / 60.0

    log.info(f'Reading SGA sample: region={args.region}')
    _, cat  = read_sga_sample(region=args.region)
    sgaid   = cat['SGAID'].value
    ra      = cat['RA'].value
    dec     = cat['DEC'].value
    objname = cat['OBJNAME'].value
    is_lvd  = (cat['SAMPLE'].value & SAMPLE_BITS['LVD']) != 0

    if args.ntest > 0:
        log.info(f'Test mode: {args.ntest} objects')
        sgaid   = sgaid[:args.ntest]
        ra      = ra[:args.ntest]
        dec     = dec[:args.ntest]
        objname = objname[:args.ntest]
        is_lvd  = is_lvd[:args.ntest]

    ned_targets = None
    if args.byname:
        ned_targets = nedfriendly_lvd(objname)
        n_translated = int(np.sum(ned_targets != objname))
        if n_translated:
            log.info(f'byname: translated {n_translated} LVD names to NED-friendly query targets')

    done = _load_done(outfile)
    if done:
        log.info(f'Resuming: {len(done)} SGAIDs already done, skipping')
    mask    = np.array([int(s) not in done for s in sgaid])
    sgaid   = sgaid[mask]
    ra      = ra[mask]
    dec     = dec[mask]
    objname = objname[mask]
    if ned_targets is not None:
        ned_targets = ned_targets[mask]

    ntotal  = len(sgaid)
    nchunks = int(np.ceil(ntotal / args.chunksize))
    if args.byname:
        log.info(f'Mode: byname | {ntotal} galaxies | {nchunks} chunks -> {outfile}')
    else:
        log.info(f'Mode: bypos (radius={args.radius}" ) | {ntotal} galaxies | '
                 f'{nchunks} chunks -> {outfile}')
    log.info(f'maxconcurrent={args.maxconcurrent}, delay={args.delay}s')

    t0    = time.time()
    ndone = 0
    for ichunk in range(nchunks):
        sl   = slice(ichunk * args.chunksize, (ichunk + 1) * args.chunksize)
        data = objname[sl] if args.byname else list(zip(ra[sl], dec[sl]))
        results = asyncio.run(
            _run_chunk(sgaid[sl], data, outfile, fields,
                       args.maxconcurrent, args.delay, args.byname, radius_arcmin,
                       ned_targets=ned_targets[sl] if ned_targets is not None else None)
        )
        ndone   += len(results)
        elapsed  = time.time() - t0
        rate     = ndone / elapsed
        eta_hr   = (ntotal - ndone) / rate / 3600 if rate > 0 else 0
        nmatch   = sum(1 for r in results if r.get('CROSSIDS'))
        nerror   = sum(1 for r in results if r.get('ERROR'))
        log.info(
            f'Chunk {ichunk+1}/{nchunks}: {len(results)} galaxies, '
            f'{nmatch} matched, {nerror} errors | '
            f'{rate:.2f} gal/s, ETA {eta_hr:.1f} hr'
        )

    log.info(f'Finished. Total elapsed: {(time.time() - t0) / 3600:.2f} hr')


def main():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument('--querytype', default='overview',
                        choices=['overview', 'redshifts', 'distances'],
                        help='NED query type (default: overview)')
    parser.add_argument('--region', default='dr11-south',
                        choices=['dr11-south', 'dr11-north'],
                        help='SGA region (default: dr11-south)')
    parser.add_argument('--outdir', required=True,
                        help='Directory for output CSV; also where redshifts/distances '
                             'querytypes look for ned-merged-{region}.fits '
                             '(see SGA2025-ned-merge)')
    parser.add_argument('--byname', action='store_true',
                        help='Overview querytype only: query by SGA OBJNAME via '
                             'OverviewOfObject (no cone search)')
    parser.add_argument('--radius', type=float, default=5.0,
                        help='Cone search radius in arcsec, overview bypos mode only '
                             '(default: 5)')
    parser.add_argument('--ntest', type=int, default=0,
                        help='Limit to first N objects for testing (0 = full run)')
    parser.add_argument('--chunksize', type=int, default=1000,
                        help='Objects per checkpoint chunk (default: 1000)')
    parser.add_argument('--maxconcurrent', type=int, default=10,
                        help='Max simultaneous NED connections (default: 10)')
    parser.add_argument('--delay', type=float, default=0.1,
                        help='Polite sleep (s) after each request (default: 0.1)')
    args = parser.parse_args()

    if args.querytype in ('redshifts', 'distances'):
        if args.byname:
            parser.error(f'--byname is not applicable to --querytype {args.querytype} '
                         '(NED_NAME is resolved from ned-byname/ned-bypos directly)')
        run_multi(args)
    else:
        run_overview(args)


if __name__ == '__main__':
    main()

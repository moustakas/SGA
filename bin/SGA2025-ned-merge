#!/usr/bin/env python
"""
SGA2025-ned-merge: merge ned-byname-{region}.csv and ned-bypos-{region}.csv
into a single per-region FITS catalog.

For each SGAID the resolution logic is:
  1. Compute BYNAME_SEP_ARCSEC: angular separation between the SGA position
     and the NED coordinates returned by the byname overview query.
  2. Use byname when any of the following hold:
       a. LVD object with successful byname match (NED coords can legitimately
          differ from SGA centroid for extended dwarfs; bypos finds background sources)
       b. byname succeeded AND OBJNAME appears in byname's CROSSIDS (confirmed
          name match; large positional offsets are expected for big galaxies where
          NED's nucleus position differs from our optical-disk centroid)
       c. byname ERROR is empty AND BYNAME_SEP_ARCSEC <= threshold (clean match)
  3. Otherwise fall back to bypos overview data and set the appropriate flag bit(s).

NED_FLAG bits
-------------
  0x01  FLAG_LARGE_SEP    byname positional offset > threshold; used bypos unless
                          name-confirmed (LVD or OBJNAME in byname CROSSIDS)
  0x02  FLAG_BYNAME_FAIL  byname error / no-match               ->  used bypos
  0x04  FLAG_BYPOS_FAIL   bypos also error / no-match           ->  result may be incomplete
  0x08  FLAG_Z_SUSPECT    adopted NED_Z > --z-swap-threshold     ->  alternates considered
  0x10  FLAG_Z_UNRESOLVED suspect but no confident replacement   ->  needs targeted VI
  0x20  FLAG_Z_MISSING    no NED_Z at all in step 1              ->  adopted from
                          RedshiftsOfObject instead (see below)

The bypos columns NED_NAME, SEPARATION_ARCSEC, and NMATCHES are always written
regardless of which source was chosen, for reference.

Redshift override (optional --redshifts-glob input)
----------------------------------------------------
This logic handles two distinct problems, both resolved against the full
RedshiftsOfObject query result for the SGAID (see SGA2025-ned-query
--querytype redshifts):

  * FLAG_Z_SUSPECT: NED occasionally assigns a bogus high-z "fiducial"
    redshift to an object (e.g. SDSS fiber contamination from a background
    source overlapping a nearby dwarf). Triggered when the adopted NED_Z
    exceeds --z-swap-threshold (default 0.4).
  * FLAG_Z_MISSING: NED's own aggregated overview has no fiducial NED_Z at
    all for the object (e.g. UGC 06451: the only overview redshift on file
    is a stale/bogus WISE photo-z, but the object has no *default* NED_Z),
    even though the full RedshiftsOfObject list has real measurements not
    yet reflected in NED's own default. Triggered whenever NED_Z is missing,
    regardless of --z-swap-threshold.

In both cases, alternative measurements with z <= --z-swap-threshold are
considered:
  1. Candidates are grouped into clusters of mutually agreeing measurements
     (relative gap |dz|/(1+z) < --z-cluster-tol, default 0.01).
  2. If one cluster is strictly the largest (including the trivial case of a
     single candidate), the highest-quality measurement within it is adopted
     -- ranked spectroscopic > photometric > other technique, then a clean
     quality flag over an uncertain ('?') one, then the most recent reference.
  3. Otherwise (tied clusters, i.e. genuinely disagreeing candidates) the
     lowest-z candidate is adopted as a best guess and FLAG_Z_UNRESOLVED is
     set. FLAG_Z_UNRESOLVED is also set (with no change to NED_Z) when there
     are zero candidates at or below threshold.
For the FLAG_Z_SUSPECT case, the original suspect value is preserved in
NED_Z_ORIG; for FLAG_Z_MISSING, NED_Z_ORIG stays NaN since there was nothing
to replace. NED_Z_NCAND/NED_Z_NALT record the number of candidates and the
size of the adopted cluster in either case. If NED_Z is missing and no
candidates are found, NED_Z is left as NaN and no flag is set -- this is the
ordinary case of a genuinely unmeasured object and should not be flagged.
This step is skipped gracefully (no flags set) when --redshifts-glob has no
file for a region.

Outputs (written to --outdir)
------------------------------
  ned-merged-dr11-south.fits
  ned-merged-dr11-north.fits

Examples
--------
  SGA2025-ned-merge --outdir /path/to/nedquery
  SGA2025-ned-merge --outdir /path/to/nedquery --region dr11-south
  SGA2025-ned-merge --outdir /path/to/nedquery --sep-threshold 5

  SGA2025-ned-merge --outdir=/Users/ioannis/research/projects/SGA/2025/sample/nedquery
  SGA2025-ned-merge --outdir /path/to/nedquery --z-swap-threshold 0.4

"""
import os
import csv
import argparse
import numpy as np
from astropy.table import Table
from astropy.coordinates import SkyCoord
import astropy.units as u

from SGA.SGA import read_sga_sample, SAMPLE as SAMPLE_BITS
from SGA.logger import log

# ---------------------------------------------------------------------------
# Flag bits
# ---------------------------------------------------------------------------
FLAG_LARGE_SEP    = 0x01   # byname offset > threshold (may still use byname if name-confirmed)
FLAG_BYNAME_FAIL  = 0x02   # byname error/no-match -> used bypos
FLAG_BYPOS_FAIL   = 0x04   # bypos also error/no-match -> result incomplete
FLAG_Z_SUSPECT    = 0x08   # adopted NED_Z > z-swap-threshold -> alternates considered
FLAG_Z_UNRESOLVED = 0x10   # suspect but no confident replacement found -> needs VI
FLAG_Z_MISSING    = 0x20   # no NED_Z at all -> adopted from RedshiftsOfObject instead

# ---------------------------------------------------------------------------
# Column type classification
# ---------------------------------------------------------------------------
# float64: coordinates and redshifts
F64_COLS = frozenset(['NED_RA', 'NED_DEC', 'NED_Z', 'NED_Z_UNC', 'NED_Z_ORIG'])

# float32: all other numeric floats
F32_COLS = frozenset([
    'NED_POS_UNC_SMA', 'NED_POS_UNC_SMI', 'NED_POS_UNC_PA',
    'NED_DIST', 'NED_DIST_UNC', 'NED_DIAM', 'NED_DIAM_KPC',
    'SEPARATION_ARCSEC', 'BYNAME_SEP_ARCSEC',
])

# int32: integer fields (SGAID uses int64, handled separately)
I32_COLS = frozenset(['N_CROSSIDS', 'NMATCHES', 'NED_FLAG', 'NED_Z_NCAND', 'NED_Z_NALT'])

# OVERVIEW_FIELDS: columns present in both byname and bypos CSVs
OVERVIEW_FIELDS = [
    'CROSSIDS', 'N_CROSSIDS',
    'NED_NOTES', 'NED_RA_S', 'NED_DEC_S', 'NED_RA', 'NED_DEC',
    'NED_POS_UNC_SMA', 'NED_POS_UNC_SMI', 'NED_POS_UNC_PA', 'NED_POS_REF',
    'NED_Z', 'NED_Z_UNC', 'NED_Z_REF',
    'NED_DIST', 'NED_DIST_UNC',
    'NED_EMREGION', 'NED_TYPE', 'NED_MORPH', 'NED_MORPH_REF',
    'NED_ACTIVITY', 'NED_ACTIVITY_REF', 'NED_OTHER',
    'NED_DIAM_BAND', 'NED_DIAM', 'NED_DIAM_REF', 'NED_DIAM_KPC',
    'NED_FOOTNOTE',
]

OUT_COLS = (
    ['SGAID', 'OBJNAME',
     'NED_NAME', 'SEPARATION_ARCSEC', 'NMATCHES',
     'BYNAME_SEP_ARCSEC', 'NED_SOURCE', 'NED_FLAG',
     'NED_ERROR_BYNAME', 'NED_ERROR_BYPOS']
    + OVERVIEW_FIELDS
    + ['NED_Z_ORIG', 'NED_Z_NCAND', 'NED_Z_NALT']
)


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
def load_csv(path):
    """Load a NED query CSV; return dict[int SGAID -> row dict], or {} if missing."""
    rows = {}
    if not os.path.exists(path):
        log.warning(f'File not found: {path}')
        return rows
    with open(path, newline='') as f:
        for row in csv.DictReader(f):
            try:
                rows[int(row['SGAID'])] = row
            except (KeyError, ValueError):
                pass
    return rows


def _fval(s, dtype):
    """Parse a CSV string to float dtype; return NaN on empty or non-numeric input."""
    try:
        return dtype(s)
    except (ValueError, TypeError):
        return dtype('nan')


def _ival(s, missing=-1):
    """Parse a CSV string to int; return missing sentinel on failure."""
    try:
        return int(s)
    except (ValueError, TypeError):
        return missing


def load_redshift_alternates(path):
    """Load a SGA2025-ned-query --querytype redshifts CSV.

    Returns dict[int SGAID -> list of measurement dicts] built from
    successful (ERROR == '') rows only, or {} if path is missing.
    """
    out = {}
    if not os.path.exists(path):
        return out
    with open(path, newline='') as f:
        for row in csv.DictReader(f):
            if row.get('ERROR', ''):
                continue
            try:
                sid = int(row['SGAID'])
                z   = float(row['NED_Z'])
            except (KeyError, ValueError):
                continue
            out.setdefault(sid, []).append({
                'z':            z,
                'unc_z':        _fval(row.get('NED_Z_UNC', ''), float),
                'z_technique':  row.get('NED_Z_TECHNIQUE', ''),
                'quality_flag': row.get('NED_Z_QUALITY', ''),
                'reference':    row.get('NED_Z_REF', ''),
            })
    return out


def _cluster_indices(zs, tol):
    """Group indices of zs into clusters via nearest-neighbor chaining in
    sorted order, with adjacent relative gap |dz|/(1+z) < tol."""
    order = sorted(range(len(zs)), key=lambda i: zs[i])
    clusters = [[order[0]]]
    for idx in order[1:]:
        prev = clusters[-1][-1]
        if abs(zs[idx] - zs[prev]) / (1.0 + zs[idx]) < tol:
            clusters[-1].append(idx)
        else:
            clusters.append([idx])
    return clusters


def _technique_rank(tech):
    """Spectroscopic ('S') is preferred over photometric ('P') over other/unknown."""
    return {'S': 0, 'P': 1}.get(str(tech).strip().upper(), 2)


def _pick_best_measurement(indices, measurements):
    """Return the index into `measurements` with the highest-quality redshift
    among `indices`: spectroscopic > photometric > other technique, then a
    clean quality flag over an uncertain ('?') one, then the most recent
    reference bibcode (first 4 characters = year)."""
    def rank(i):
        m         = measurements[i]
        tech_rank = _technique_rank(m['z_technique'])
        qual_rank = 1 if '?' in str(m['quality_flag']) else 0
        try:
            year = -int(str(m['reference'])[:4])
        except ValueError:
            year = 0
        return (tech_rank, qual_rank, year)
    return min(indices, key=rank)


def resolve_redshift_override(measurements, swap_threshold, cluster_tol):
    """Pick a replacement for a suspect (> swap_threshold) adopted NED_Z from
    the full list of RedshiftsOfObject measurements for one SGAID.

    Candidates (z <= swap_threshold) are grouped into clusters of mutually
    agreeing values. If one cluster is strictly the largest (including the
    trivial single-candidate case), the highest-quality measurement within it
    is adopted (confident). Otherwise -- tied clusters, i.e. genuinely
    disagreeing candidates -- the lowest-z candidate is adopted as a best
    guess and marked unresolved. Returns None if there are no candidates.
    """
    candidates = [m for m in measurements if m['z'] <= swap_threshold]
    if not candidates:
        return None

    zs       = [m['z'] for m in candidates]
    clusters = _cluster_indices(zs, cluster_tol)
    maxsize  = max(len(c) for c in clusters)
    winners  = [c for c in clusters if len(c) == maxsize]

    if len(winners) == 1:
        best       = _pick_best_measurement(winners[0], candidates)
        unresolved = False
    else:
        best       = min(range(len(candidates)), key=lambda i: candidates[i]['z'])
        unresolved = True

    m = candidates[best]
    return {
        'z': m['z'], 'unc_z': m['unc_z'], 'reference': m['reference'],
        'unresolved': unresolved, 'n_candidates': len(candidates), 'n_cluster': maxsize,
    }


# ---------------------------------------------------------------------------
# Per-region merge
# ---------------------------------------------------------------------------
def merge_region(region, outdir, sep_threshold, redshifts_glob,
                 z_swap_threshold, z_cluster_tol):
    byname_path    = os.path.join(outdir, f'ned-byname-{region}.csv')
    bypos_path     = os.path.join(outdir, f'ned-bypos-{region}.csv')
    redshifts_path = os.path.join(outdir, redshifts_glob.format(region=region))
    outpath        = os.path.join(outdir, f'ned-merged-{region}.fits')

    log.info(f'Loading {region}')
    byname = load_csv(byname_path)
    bypos  = load_csv(bypos_path)
    log.info(f'  byname: {len(byname):,d} rows   bypos: {len(bypos):,d} rows')

    redshift_alts = load_redshift_alternates(redshifts_path)
    if redshift_alts:
        log.info(f'  redshift alternates: {len(redshift_alts):,d} SGAIDs from {redshifts_path}')
    else:
        log.info(f'  redshift alternates: {redshifts_path} not found or empty, '
                 'skipping z-override logic')

    _, cat  = read_sga_sample(region=region)
    sga_id  = cat['SGAID'].value
    sga_ra  = cat['RA'].value
    sga_dec = cat['DEC'].value
    sga_obj = cat['OBJNAME'].value
    n = len(sga_id)
    log.info(f'  SGA sample: {n:,d} objects')

    # LVD dwarfs: always trust a successful byname match regardless of
    # positional offset.  Their NED coordinates can legitimately differ
    # from the SGA centroid; bypos at the SGA position finds compact
    # background sources instead of the extended dwarf.
    lvd_sgaids = set(
        int(s) for s in sga_id[(cat['SAMPLE'].value & SAMPLE_BITS['LVD']) != 0]
    )
    log.info(f'  LVD objects: {len(lvd_sgaids):,d}')

    # Pre-compute byname positional separations vectorially.
    # Only attempt for rows where byname returned no error.
    ned_ra  = np.full(n, np.nan)
    ned_dec = np.full(n, np.nan)
    for i in range(n):
        brow = byname.get(int(sga_id[i]), {})
        if brow.get('ERROR', 'x') == '':
            try:
                ned_ra[i]  = float(brow['NED_RA'])
                ned_dec[i] = float(brow['NED_DEC'])
            except (KeyError, ValueError, TypeError):
                pass

    byname_seps = np.full(n, np.nan)
    valid = ~(np.isnan(ned_ra) | np.isnan(ned_dec))
    if np.any(valid):
        c1 = SkyCoord(ra=sga_ra[valid] * u.deg, dec=sga_dec[valid] * u.deg)
        c2 = SkyCoord(ra=ned_ra[valid] * u.deg, dec=ned_dec[valid] * u.deg)
        byname_seps[valid] = c1.separation(c2).arcsec
    log.info(f'  Separations computed for {int(np.sum(valid)):,d} byname positions')

    # Build output columns
    cols = {c: [] for c in OUT_COLS}

    for i in range(n):
        sid  = int(sga_id[i])
        brow = byname.get(sid, {})
        prow = bypos.get(sid, {})

        byname_err = brow.get('ERROR', 'missing')
        bypos_err  = prow.get('ERROR', 'missing')
        byname_sep = byname_seps[i]

        flag = 0
        if byname_err != '':
            flag |= FLAG_BYNAME_FAIL
        elif np.isnan(byname_sep) or byname_sep > sep_threshold:
            flag |= FLAG_LARGE_SEP
        if flag and bypos_err != '':
            flag |= FLAG_BYPOS_FAIL

        # Check whether byname's CROSSIDS confirm the object name. When True,
        # byname is preferred even with a large positional offset because the
        # offset reflects the difference between NED's nucleus position and our
        # optical-disk centroid — common for large galaxies (e.g. NGC 4945).
        byname_name_confirmed = False
        if byname_err == '':
            byname_crossids = brow.get('CROSSIDS', '')
            obj_upper = str(sga_obj[i]).strip().upper()
            byname_name_confirmed = any(
                c.strip().upper() == obj_upper
                for c in byname_crossids.split('|')
                if c.strip()
            )

        # Source selection:
        #   LVD + byname ok                   -> byname (large dwarfs have genuine NED offsets;
        #                                          bypos finds compact background sources)
        #   name confirmed in byname CROSSIDS  -> byname (NED matched the right galaxy;
        #                                          large sep expected for extended sources)
        #   flag == 0                          -> byname (clean)
        #   LARGE_SEP, bypos ok               -> bypos  (NED position off, bypos rescued it)
        #   LARGE_SEP, bypos also failed      -> byname (NED pos off but name match still valid)
        #   BYNAME_FAIL, bypos ok             -> bypos
        #   BYNAME_FAIL, bypos also failed    -> none
        if byname_err == '' and (sid in lvd_sgaids or byname_name_confirmed):
            src, source_str = brow, 'byname'
        elif flag == 0:
            src, source_str = brow, 'byname'
        elif not (flag & FLAG_BYPOS_FAIL):
            src, source_str = prow, 'bypos'
        elif not (flag & FLAG_BYNAME_FAIL):
            src, source_str = brow, 'byname'   # position off but name match still valid
        else:
            src, source_str = {}, 'none'

        # Identification and resolution columns
        cols['SGAID'].append(sid)
        cols['OBJNAME'].append(str(sga_obj[i]))
        ned_name = str(prow.get('NED_NAME', ''))
        if not ned_name:
            crossids_raw = src.get('CROSSIDS', '')
            if crossids_raw:
                ned_name = crossids_raw.split('|')[0].strip()
        cols['NED_NAME'].append(ned_name)
        cols['SEPARATION_ARCSEC'].append(_fval(prow.get('SEPARATION_ARCSEC', ''), np.float32))
        cols['NMATCHES'].append(_ival(prow.get('NMATCHES', '')))
        cols['BYNAME_SEP_ARCSEC'].append(np.float32(byname_sep))
        cols['NED_SOURCE'].append(source_str)
        cols['NED_FLAG'].append(np.int32(flag))
        cols['NED_ERROR_BYNAME'].append(byname_err)
        cols['NED_ERROR_BYPOS'].append(bypos_err)

        # OVERVIEW_FIELDS from the winning source
        for col in OVERVIEW_FIELDS:
            raw = src.get(col, '')
            if col in F64_COLS:
                cols[col].append(_fval(raw, np.float64))
            elif col in F32_COLS:
                cols[col].append(_fval(raw, np.float32))
            elif col in I32_COLS:
                cols[col].append(_ival(raw))
            else:
                cols[col].append(str(raw))

        # Redshift override: two distinct problems, both resolved against the
        # object's full RedshiftsOfObject measurements.
        #  - FLAG_Z_SUSPECT: NED assigned a bogus high fiducial redshift (e.g.
        #    SDSS fiber contamination from a background source); triggered
        #    when the adopted default exceeds z_swap_threshold.
        #  - FLAG_Z_MISSING: NED's overview has no default NED_Z at all, even
        #    though real measurements exist in the full query (e.g. UGC 06451).
        zval      = cols['NED_Z'][-1]
        z_orig    = np.nan
        n_cand    = 0
        n_alt     = 0
        z_missing = np.isnan(zval)
        z_suspect = (not z_missing) and zval > z_swap_threshold
        if z_missing or z_suspect:
            if z_suspect:
                flag |= FLAG_Z_SUSPECT
                z_orig = zval
            measurements = redshift_alts.get(sid)
            result = (resolve_redshift_override(measurements, z_swap_threshold, z_cluster_tol)
                      if measurements else None)
            if result is None:
                if z_suspect:
                    flag |= FLAG_Z_UNRESOLVED
                # z_missing with no candidates: leave NED_Z as NaN, no flag --
                # this is the ordinary unmeasured case, not worth flagging.
            else:
                if z_missing:
                    flag |= FLAG_Z_MISSING
                cols['NED_Z'][-1]     = result['z']
                cols['NED_Z_UNC'][-1] = result['unc_z']
                cols['NED_Z_REF'][-1] = result['reference']
                n_cand = result['n_candidates']
                n_alt  = result['n_cluster']
                if result['unresolved']:
                    flag |= FLAG_Z_UNRESOLVED
        cols['NED_Z_ORIG'].append(np.float64(z_orig))
        cols['NED_Z_NCAND'].append(np.int32(n_cand))
        cols['NED_Z_NALT'].append(np.int32(n_alt))
        cols['NED_FLAG'][-1] = np.int32(flag)

    # Assemble and write the FITS table
    t = Table()
    for col in OUT_COLS:
        vals = cols[col]
        if col in F64_COLS:
            t[col] = np.array(vals, dtype=np.float64)
        elif col in F32_COLS:
            t[col] = np.array(vals, dtype=np.float32)
        elif col == 'SGAID':
            t[col] = np.array(vals, dtype=np.int64)
        elif col in I32_COLS:
            t[col] = np.array(vals, dtype=np.int32)
        else:
            t[col] = vals   # astropy infers fixed-length string for FITS

    t.write(outpath, overwrite=True)
    log.info(f'  Wrote {outpath}')

    # Summary statistics -> stdout
    flags   = t['NED_FLAG']
    sources = np.asarray(t['NED_SOURCE'])
    n_byname = int(np.sum(sources == 'byname'))
    n_bypos  = int(np.sum(sources == 'bypos'))
    n_none   = int(np.sum(sources == 'none'))
    n_large  = int(np.sum((flags & FLAG_LARGE_SEP)   != 0))
    n_bfail  = int(np.sum((flags & FLAG_BYNAME_FAIL)  != 0))
    n_pfail  = int(np.sum((flags & FLAG_BYPOS_FAIL)   != 0))
    n_zsus   = int(np.sum((flags & FLAG_Z_SUSPECT)    != 0))
    n_zunres = int(np.sum((flags & FLAG_Z_UNRESOLVED) != 0))
    n_zmiss  = int(np.sum((flags & FLAG_Z_MISSING)    != 0))
    n_any    = int(np.sum(flags != 0))

    sga_id_set  = set(int(x) for x in sga_id)
    n_no_byname = len(sga_id_set - set(byname.keys()))
    n_no_bypos  = len(sga_id_set - set(bypos.keys()))

    pct = lambda k: 100.0 * k / n if n else 0.0

    print(f'\n--- {region} summary ({n:,d} galaxies, sep threshold {sep_threshold:.1f}") ---')
    print(f'  LVD objects (byname always trusted) : {len(lvd_sgaids):>8,d}')
    print(f'  NED_SOURCE = byname  : {n_byname:>8,d}  ({pct(n_byname):5.1f}%)')
    print(f'  NED_SOURCE = bypos   : {n_bypos:>8,d}  ({pct(n_bypos):5.1f}%)')
    print(f'  NED_SOURCE = none    : {n_none:>8,d}  ({pct(n_none):5.1f}%)')
    print()
    print( '  NED_FLAG bits:')
    print(f'    LARGE_SEP    (0x01) : {n_large:>8,d}  ({pct(n_large):5.1f}%)')
    print(f'    BYNAME_FAIL  (0x02) : {n_bfail:>8,d}  ({pct(n_bfail):5.1f}%)')
    print(f'    BYPOS_FAIL   (0x04) : {n_pfail:>8,d}  ({pct(n_pfail):5.1f}%)')
    print(f'    Z_SUSPECT    (0x08) : {n_zsus:>8,d}  ({pct(n_zsus):5.1f}%)  '
          f'(resolved: {n_zsus - n_zunres:,d})')
    print(f'    Z_UNRESOLVED (0x10) : {n_zunres:>8,d}  ({pct(n_zunres):5.1f}%)')
    print(f'    Z_MISSING    (0x20) : {n_zmiss:>8,d}  ({pct(n_zmiss):5.1f}%)')
    print(f'    any flag set        : {n_any:>8,d}  ({pct(n_any):5.1f}%)')
    print()
    print(f'  Missing from byname CSV : {n_no_byname:>8,d}')
    print(f'  Missing from bypos  CSV : {n_no_bypos:>8,d}')


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument('--outdir', required=True,
                        help='Directory containing input CSVs and for output FITS')
    parser.add_argument('--region', choices=['dr11-south', 'dr11-north'],
                        help='Process one region only (default: both)')
    parser.add_argument('--sep-threshold', type=float, default=3.5,
                        help='Byname positional offset threshold in arcsec (default: 3.5)')
    parser.add_argument('--redshifts-glob', default='ned-redshifts-{region}.csv',
                        help='Filename template (relative to --outdir) for the optional '
                             'RedshiftsOfObject override data produced by SGA2025-ned-query '
                             '--querytype redshifts; {region} is substituted. Skipped '
                             'gracefully if not found (default: ned-redshifts-{region}.csv)')
    parser.add_argument('--z-swap-threshold', type=float, default=0.4,
                        help='Adopted NED_Z above this value triggers consideration of '
                             'alternative redshift measurements (default: 0.4)')
    parser.add_argument('--z-cluster-tol', type=float, default=0.01,
                        help='Relative tolerance |dz|/(1+z) for grouping repeat redshift '
                             'measurements into the same cluster (default: 0.01)')
    args = parser.parse_args()

    regions = [args.region] if args.region else ['dr11-south', 'dr11-north']
    for region in regions:
        merge_region(region, args.outdir, args.sep_threshold,
                     args.redshifts_glob, args.z_swap_threshold, args.z_cluster_tol)


if __name__ == '__main__':
    main()

#!/usr/bin/env python
"""
SGA2025-qa-redshifts: find high-redshift SGA2025 objects worth a human look,
and write a VI worksheet that SGA2025-build-catalog can read back in.

This script does not change any catalog values. It classifies each
high-redshift object into exactly one action category and writes a CSV
worksheet -- fill in the VI_* columns by hand, then pass the same file to
SGA2025-build-catalog --vi-redshifts to apply your decisions.

Population and threshold
-------------------------
Audits every row of the merged, non-deduplicated catalog (fullsample from
read_sga_sample, i.e. all group members, not just GROUP_PRIMARY) with
Z_IVAR > 0 and Z above --z-threshold (default: the --percentile-th
percentile of the Z distribution, 99th by default).

Objects SGA2025-build-catalog already auto-resolved (Z_FLAG has
CONSENSUS_OVERRIDE, AUTO_NED_OVERRIDE, or VI_REVIEWED set) are excluded
from every category below -- they don't need VI, and for OVERRIDE
specifically, the raw Z_DESI/Z_SDSS/Z_NED columns keep their pre-override
values, so re-checking them would flag an already-fixed object again.

Action categories (mutually exclusive)
---------------------------------------
OVERRIDE   The adopted Z disagrees with every other available measurement
           (LVD, DESI, SDSS, NED -- see the Z_{SRC} columns in the
           worksheet) by more than --override-vdiff-threshold (default
           5000 km/s, deliberately looser than build-catalog's own
           --vdiff-threshold used for Z_FLAG DISCREPANCY: that bit is a
           general-purpose science flag and fires on differences as small
           as 1000 km/s, which a coarse literature NED redshift can exceed
           even when DESI and SDSS agree with each other -- not a genuine
           problem). The alternative value is already sitting in the same
           row; decide which (if either) is right.

DISCARD_UNRESOLVED   Z_REF = NED and NED_FLAG has Z_UNRESOLVED set:
           SGA2025-ned-merge already tried and failed to find a confident
           replacement among NED's own redshift measurements. No
           alternative exists in the catalog; the only options are to
           accept NED's best guess or discard it. A row can also qualify
           for OVERRIDE (a NED-sourced Z can simultaneously disagree with
           another catalog's measurement); OVERRIDE takes priority in that
           case, since a concrete cross-catalog alternative is more
           actionable than "no alternative exists".

DISCARD_UNVERIFIED   Z_REF is DESI or SDSS, it is the only measurement for
           this object (no LVD/other DESI or SDSS/NED value to cross-check
           against), and Z >= --sole-threshold. Neither DESI's nor SDSS's
           own quality flags (ZWARN, DELTACHI2) can tell a real high-z
           fit from a fiber landing on a background source, so these need
           a direct look; there is no alternative to swap in.

VI worksheet
------------
Written to --write-candidates, one row per flagged object, sorted by
action then descending Z. Columns starting with VI_ are blank -- fill in:
  VI_STATUS  'ok' (confirmed correct, no change), 'discard' (zero out the
             redshift), or 'override' (replace with VI_Z/VI_Z_IVAR)
  VI_Z, VI_Z_IVAR   required when VI_STATUS = 'override'
  VI_NOTES   free text
Rows with a blank VI_STATUS are left untouched by SGA2025-build-catalog
--vi-redshifts, so the same file can be re-run through this pass repeatedly
as you work through it.

Examples
--------
  SGA2025-qa-redshifts --write-candidates zqa-vi.csv
  SGA2025-qa-redshifts --z-threshold 0.2 --sole-threshold 0.3 \\
      --write-candidates zqa-vi.csv
"""
import os
import sys
import argparse

import numpy as np
from astropy.table import Column

from SGA.SGA import read_sga_sample
from SGA.util import C_LIGHT
from SGA.logger import log

# Must match bin/SGA2025-ned-merge.
NED_FLAG_Z_UNRESOLVED = 0x10

# Must match bin/SGA2025-build-catalog.
Z_FLAG_CONSENSUS_OVERRIDE = 0x10
Z_FLAG_AUTO_NED_OVERRIDE  = 0x20
Z_FLAG_VI_REVIEWED        = 0x40
Z_FLAG_ALREADY_RESOLVED = (Z_FLAG_CONSENSUS_OVERRIDE | Z_FLAG_AUTO_NED_OVERRIDE |
                          Z_FLAG_VI_REVIEWED)

SOURCES = ['LVD', 'DESI', 'SDSS', 'NED']   # must match the Z_{SRC}/Z_IVAR_{SRC} columns

CANDIDATE_COLS = [
    'SGAID', 'GALAXY', 'Z_FLAG', 'NED_FLAG', 'Z_REF', 'Z',
    'Z_DESI', 'Z_SDSS', 'Z_NED', 'Z_LVD',
    'Z_IVAR_DESI', 'Z_IVAR_SDSS', 'Z_IVAR_NED', 'Z_IVAR_LVD',
]
VI_COLS = ['VI_STATUS', 'VI_Z', 'VI_Z_IVAR', 'VI_NOTES']


def _vdiff_kms(z1, z2):
    """Rest-frame velocity difference (km/s) between two redshifts; array or
    scalar. Same formula as SGA2025-build-catalog's Z_FLAG_DISCREPANCY check."""
    return C_LIGHT * np.abs(z1 - z2) / (1. + np.minimum(z1, z2))


def main():
    parser = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument('--version', default=None,
                        help='Catalog version (default: current release version)')
    parser.add_argument('--primary-only', action='store_true',
                        help='Audit only GROUP_PRIMARY objects instead of the default '
                             'full sample (all group members)')
    parser.add_argument('--percentile', type=float, default=99.,
                        help='Percentile of the Z_IVAR>0 redshift distribution used to set '
                             'the high-z threshold when --z-threshold is not given (default: 99)')
    parser.add_argument('--z-threshold', type=float, default=None,
                        help='Explicit redshift threshold, overriding --percentile')
    parser.add_argument('--sole-threshold', type=float, default=0.3,
                        help='DISCARD_UNVERIFIED cutoff: sole-source DESI/SDSS redshifts at '
                             'or above this value are flagged for VI (default: 0.3)')
    parser.add_argument('--override-vdiff-threshold', type=float, default=5000.,
                        help='OVERRIDE cutoff: the adopted Z must disagree with every other '
                             'available measurement by more than this (km/s) to be flagged. '
                             'Deliberately looser than build-catalog\'s own --vdiff-threshold '
                             '(default: 5000)')
    parser.add_argument('--write-candidates', default=None,
                        help='Path to write the VI worksheet CSV')
    parser.add_argument('--overwrite', action='store_true',
                        help='Overwrite an existing --write-candidates file (otherwise '
                             'refuses, to avoid clobbering completed VI work)')
    args = parser.parse_args()

    if args.write_candidates and not args.overwrite and os.path.isfile(args.write_candidates):
        log.error(f'Output exists (use --overwrite): {args.write_candidates}')
        return 1

    sample, fullsample = read_sga_sample(version=args.version)
    t = sample if args.primary_only else fullsample
    log.info(f'Auditing {len(t):,d} objects '
             f'({"GROUP_PRIMARY only" if args.primary_only else "full sample"})')

    z        = np.array(t['Z'])
    ivar     = np.array(t['Z_IVAR'])
    zref     = np.array(t['Z_REF'])
    zflag    = np.array(t['Z_FLAG'])
    nedflag  = np.array(t['NED_FLAG'])
    z_src    = {src: np.array(t[f'Z_{src}'])      for src in SOURCES}
    ivar_src = {src: np.array(t[f'Z_IVAR_{src}']) for src in SOURCES}

    has_z = ivar > 0
    if args.z_threshold is not None:
        z_threshold = args.z_threshold
    else:
        z_threshold = float(np.percentile(z[has_z], args.percentile))
    hi = has_z & (z > z_threshold)

    already_resolved = (zflag & Z_FLAG_ALREADY_RESOLVED) != 0

    n_valid = sum((ivar_src[src] > 0).astype(int) for src in SOURCES)

    # OVERRIDE: the adopted Z is corroborated by another source (agrees within
    # --override-vdiff-threshold) only if it wasn't already resolved by
    # build-catalog. A source "corroborates" if it's valid, isn't the one
    # already adopted, and is close to the adopted Z.
    any_other_valid = np.zeros(len(t), dtype=bool)
    corroborated    = np.zeros(len(t), dtype=bool)
    for src in SOURCES:
        other_valid = (ivar_src[src] > 0) & (zref != src)
        any_other_valid |= other_valid
        corroborated    |= (other_valid &
                            (_vdiff_kms(z, z_src[src]) <= args.override_vdiff_threshold))
    override = hi & ~already_resolved & any_other_valid & ~corroborated

    discard_unresolved = (hi & ~already_resolved & (zref == 'NED') &
                         ((nedflag & NED_FLAG_Z_UNRESOLVED) != 0))
    discard_unverified = (hi & ~already_resolved & (n_valid == 1) &
                          np.isin(zref, ['DESI', 'SDSS']) & (z >= args.sole_threshold))

    # OVERRIDE and DISCARD_UNRESOLVED test unrelated things (cross-catalog
    # disagreement vs. NED's own internal alternate-resolution failure) and
    # can both be true for the same NED-sourced row. OVERRIDE wins: a
    # concrete cross-catalog alternative in the same row is more actionable
    # than "no alternative exists".
    overlap = override & discard_unresolved
    if np.any(overlap):
        log.info(f'{int(overlap.sum()):,d} objects satisfy both OVERRIDE and '
                 f'DISCARD_UNRESOLVED; classifying as OVERRIDE (cross-catalog '
                 f'alternative takes priority)')
    discard_unresolved &= ~override

    action = np.full(len(t), '', dtype='U20')
    action[override]           = 'OVERRIDE'
    action[discard_unresolved] = 'DISCARD_UNRESOLVED'
    action[discard_unverified] = 'DISCARD_UNVERIFIED'
    flagged = action != ''

    print(f'\n--- SGA2025-qa-redshifts (n={len(t):,d}, Z_IVAR>0: {int(has_z.sum()):,d}) ---')
    print(f'z threshold = {z_threshold:.4f} '
          f'({"explicit" if args.z_threshold is not None else f"{args.percentile:g}th percentile"})')
    print(f'n(Z_IVAR>0, Z>{z_threshold:.4f}) = {int(hi.sum()):,d}\n')

    print('By Z_REF:')
    for src in sorted(set(zref[hi])):
        m = hi & (zref == src)
        print(f'  {src or "(none)":8s}: {int(m.sum()):6,d}  '
              f'(min={z[m].min():.4f} median={np.median(z[m]):.4f} max={z[m].max():.4f})')

    n_auto = int(np.sum(hi & already_resolved))
    print(f'\nAlready auto-resolved by build-catalog (excluded below): {n_auto:6,d}')

    print('\nAction categories:')
    print(f'  OVERRIDE            : {int(override.sum()):6,d}  '
          f'(disagrees with every other source by > {args.override_vdiff_threshold:g} km/s)')
    print(f'  DISCARD_UNRESOLVED  : {int(discard_unresolved.sum()):6,d}  '
          f'(sole NED measurement, ned-merge could not resolve it)')
    print(f'  DISCARD_UNVERIFIED  : {int(discard_unverified.sum()):6,d}  '
          f'(sole DESI/SDSS measurement, no cross-check possible)')
    print(f'  Total flagged for VI: {int(flagged.sum()):6,d} / {int(hi.sum()):,d} '
          f'({100.*flagged.sum()/hi.sum():.1f}%)')

    if args.write_candidates:
        if not np.any(flagged):
            log.info(f'  No candidates -- not writing {args.write_candidates}')
            return 0
        idx = np.where(flagged)[0]
        out = t[CANDIDATE_COLS][idx]
        out.add_column(Column(action[idx], name='ACTION_HINT'), index=1)
        for col in VI_COLS:
            out[col] = np.full(len(out), '', dtype='U40')
        order = np.lexsort((-np.array(out['Z']), np.array(out['ACTION_HINT'])))
        out = out[order]
        out.write(args.write_candidates, format='csv', overwrite=args.overwrite)
        log.info(f'  Wrote {len(out):,d} VI candidates to {args.write_candidates}')

    return 0


if __name__ == '__main__':
    sys.exit(main())

#!/usr/bin/env python

import numpy as np
import fitsio, pdb
from astropy.table import Table
from astropy.coordinates import SkyCoord
import astropy.units as u
from SGA.external import read_sga2020
from SGA.util import match
from SGA.logger import log

nn = Table(fitsio.read('SGA2025-beta-parent-v1.2.fits'))
sga = read_sga2020()
sga = sga['GALAXY', 'GROUP_NAME', 'RA', 'DEC', 'D26', 'PA', 'BA', 'MAG_LEDA']

#adds = Table.read('~/code/SGA/py/SGA/data/SGA2025/overlays/v1.1/adds.csv', format='csv')
#drop_groups = sga[np.isin(sga['GALAXY'], adds['OBJNAME'])]['GROUP_NAME'].value
#print(f'Dropping {len(drop_groups)} groups')
#sga = sga[~np.isin(sga['GROUP_NAME'], drop_groups)]

mindiam = 0.8 # 2.0  # arcmin - tunable
maxdiam = 0.85 # 1e3

# Focus on large SGA2020 galaxies
I = (sga['D26'] >= mindiam) & (sga['D26'] < maxdiam)
sga_large = sga[I]
log.info(f"SGA2020 galaxies with D26 >= {mindiam}': {len(sga_large):,d}")

# Coordinates
coords_2020 = SkyCoord(sga_large['RA'] * u.deg, sga_large['DEC'] * u.deg)
coords_2025 = SkyCoord(nn['RA'] * u.deg, nn['DEC'] * u.deg)

# For each SGA2020 galaxy, find nearest SGA2025 match
idx_2025, sep, _ = coords_2020.match_to_catalog_sky(coords_2025)

# Compute separation in units of the SGA2020 diameter
# A match within ~0.5 diameters is probably the same galaxy
sep_arcmin = sep.to(u.arcmin).value
sep_in_diameters = sep_arcmin / sga_large['D26']

# Also check if matched SGA2025 galaxy has similar size
diam_2025 = nn['DIAM'][idx_2025]
diam_ratio = diam_2025 / sga_large['D26']

# Flag as "missing" if:
# 1. Separation > 0.5 diameters (center too far) OR
# 2. Separation > 1 arcmin AND diameter ratio very different (<0.3 or >3)
too_far = sep_in_diameters > 0.5
very_different_size = (sep_arcmin > 1.0) & ((diam_ratio < 0.3) | (diam_ratio > 3.0))

possibly_missing = too_far | very_different_size

log.info(f"\nMatching results:")
log.info(f"  Good matches (sep < 0.5 diameters): {np.sum(~too_far):,d}")
log.info(f"  Too far (sep > 0.5 diameters): {np.sum(too_far):,d}")
log.info(f"  Very different size: {np.sum(very_different_size):,d}")
log.info(f"  Possibly missing: {np.sum(possibly_missing):,d}")

# Build inspection table
inspect = Table()
inspect['GALAXY_2020'] = sga_large['GALAXY']
inspect['GROUP_2020'] = sga_large['GROUP_NAME']
inspect['RA_2020'] = sga_large['RA']
inspect['DEC_2020'] = sga_large['DEC']
inspect['D26_2020'] = sga_large['D26']
inspect['BA_2020'] = sga_large['BA']
inspect['PA_2020'] = sga_large['PA']

inspect['NEAREST_2025'] = nn['OBJNAME'][idx_2025]
inspect['RA_2025'] = nn['RA'][idx_2025]
inspect['DEC_2025'] = nn['DEC'][idx_2025]
inspect['DIAM_2025'] = diam_2025

inspect['SEP_ARCMIN'] = sep_arcmin
inspect['SEP_IN_DIAM'] = sep_in_diameters
inspect['DIAM_RATIO'] = diam_ratio

inspect['TOO_FAR'] = too_far
inspect['VERY_DIFF_SIZE'] = very_different_size
inspect['POSSIBLY_MISSING'] = possibly_missing

# Sort by diameter (largest first)
missing = inspect[possibly_missing]
missing = missing[np.argsort(missing['D26_2020'])[::-1]]
missing = missing[np.argsort(missing['DEC_2020'])[::-1]]

log.info(f"\nTop 20 possibly missing (largest first):")
print(missing['GALAXY_2020', 'D26_2020', 'NEAREST_2025', 'DIAM_2025', 'SEP_ARCMIN', 'SEP_IN_DIAM', 'DIAM_RATIO'][:20])

# Summary by separation
log.info(f"\nBreakdown of possibly missing by separation:")
log.info(f"  Sep < 1': {np.sum(missing['SEP_ARCMIN'] < 1):,d}")
log.info(f"  Sep 1-5': {np.sum((missing['SEP_ARCMIN'] >= 1) & (missing['SEP_ARCMIN'] < 5)):,d}")
log.info(f"  Sep 5-30': {np.sum((missing['SEP_ARCMIN'] >= 5) & (missing['SEP_ARCMIN'] < 30)):,d}")
log.info(f"  Sep > 30': {np.sum(missing['SEP_ARCMIN'] >= 30):,d}")

## Write out for inspection
#missing.write('sga2020-possibly-missing.fits', overwrite=True)
#log.info(f"\nWrote {len(missing)} objects to sga2020-possibly-missing.fits")

# Also create viewer table using SGA2020 coordinates
from SGA.qa import to_skyviewer_table
view_table = Table()
view_table['RA'] = missing['RA_2020']
view_table['DEC'] = missing['DEC_2020']
view_table['BA'] = missing['BA_2020']
view_table['PA'] = missing['PA_2020']
view_table['DIAM'] = missing['D26_2020']
view_table['OBJNAME'] = missing['GALAXY_2020']
view_table['GROUP_RA'] = missing['RA_2020']
view_table['GROUP_DEC'] = missing['DEC_2020']
view = to_skyviewer_table(view_table)
view.write('~/Downloads/missing-sga2020.fits', overwrite=True)
log.info(f"Wrote viewer file to ~/Downloads/missing-sga2020.fits")

print()
for grp in missing['GROUP_2020'].value:
    I = np.isin(sga['GROUP_NAME'], grp)
    for one in sga[I]:
        if one['DEC'] > 30.:
            reg = 'dr9-north'
        else:
            reg = 'dr11-south'
        print(f"{one['GALAXY']},{reg},{one['RA']},{one['DEC']},{one['D26']:.3f},{one['PA']:.1f},{one['BA']:.3f},{one['MAG_LEDA']:.3f},SGA2020 dropped")
    print()

print(len(view))

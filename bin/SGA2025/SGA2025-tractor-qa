def write_viewer_file(sample, viewerfile: str, diamcolumn: str):
    """Write FITS file for Legacy Survey viewer overlay."""
    view = sample['OBJNAME', 'RA', 'DEC', diamcolumn, 'BA', 'PA'].copy()
    view.rename_columns(
        ['OBJNAME', 'RA', 'DEC', diamcolumn, 'BA', 'PA'],
        ['name', 'ra', 'dec', 'radius', 'abRatio', 'posAngle']
    )
    # Convert diameter to radius in arcsec
    view['radius'] = view['radius'] * 60. / 2.
    view.write(viewerfile, overwrite=True)
    log.debug(f'Wrote {viewerfile}')


def find_missing_sga2020(fullsample_2025, sga2020_mindiam=0.6, sga2020_maxdiam=0.7,
                         sga2020_groups_only=False, region='dr11-south'):
    """
    Find SGA2020 groups with possibly missing members and build mock catalog.

    Returns
    -------
    sample : Table
        Mock SGA2025-like table of SGA2020 GROUP_PRIMARY objects
    fullsample : Table
        Mock SGA2025-like table of all SGA2020 group members
    sga2025_overlay : Table
        Nearby SGA2025 sources for overlay annotation

    """
    from SGA.external import read_sga2020
    from astropy.coordinates import SkyCoord
    import astropy.units as u

    dec_cut = 32.

    sga2020_full = read_sga2020(region=region)

    # Select SGA2020 objects in diameter range for "missing" check
    in_range = (sga2020_full['D26'] >= sga2020_mindiam) & (sga2020_full['D26'] < sga2020_maxdiam)
    #if region == 'dr11-south':
    #    in_range &= sga2020_full['DEC'] < 32.275
    #else:
    #    in_range &= sga2020_full['DEC'] > 32.275

    sga2020_check = sga2020_full[in_range]
    log.info(f'SGA2020 galaxies with D26 in [{sga2020_mindiam}, {sga2020_maxdiam}): {len(sga2020_check):,d}')

    # Match to SGA2025
    coords_2020 = SkyCoord(sga2020_check['RA'] * u.deg, sga2020_check['DEC'] * u.deg)
    coords_2025 = SkyCoord(fullsample_2025['RA'] * u.deg, fullsample_2025['DEC'] * u.deg)
    idx_2025, sep, _ = coords_2020.match_to_catalog_sky(coords_2025)

    sep_arcmin = sep.to(u.arcmin).value
    sep_in_diameters = sep_arcmin / sga2020_check['D26']
    diam_ratio = fullsample_2025['DIAM'][idx_2025] / sga2020_check['D26']

    too_far = sep_in_diameters > 0.5
    very_different_size = (sep_arcmin > 1.0) & ((diam_ratio < 0.3) | (diam_ratio > 3.0))
    possibly_missing = too_far | very_different_size

    log.info(f'Possibly missing: {np.sum(possibly_missing):,d}')

    if np.sum(possibly_missing) == 0:
        log.warning('No possibly missing SGA2020 galaxies found.')
        return None, None, None

    # Get SGA2020 GROUP_NAMEs with at least one missing member
    missing_group_names = np.unique(sga2020_check['GROUP_NAME'][possibly_missing])
    log.info(f'SGA2020 groups with missing members: {len(missing_group_names):,d}')

    if sga2020_groups_only:
        # Keep ALL members of those groups from the full SGA2020 catalog
        sga2020_groups = sga2020_full[np.isin(sga2020_full['GROUP_NAME'], missing_group_names)]
        log.info(f'Total SGA2020 objects in those groups: {len(sga2020_groups):,d}')
    else:
        # Keep only the missing objects themselves
        sga2020_groups = sga2020_check[possibly_missing]
        log.info(f'Missing SGA2020 objects only: {len(sga2020_groups):,d}')

    # Build mock SGA2025-like table using existing SGA2020 columns
    #group_diameter = np.maximum(sga2020_groups['GROUP_DIAMETER'], sga2020_groups['D26'])

    mock = Table()
    mock['SGAID'] = np.arange(len(sga2020_groups), dtype=np.int64)
    mock['OBJNAME'] = sga2020_groups['GALAXY']
    mock['RA'] = sga2020_groups['RA']
    mock['DEC'] = sga2020_groups['DEC']
    mock['DIAM'] = sga2020_groups['D26']
    mock['BA'] = sga2020_groups['BA']
    mock['PA'] = sga2020_groups['PA']
    mock['MAG'] = sga2020_groups['MAG_LEDA']
    mock['GROUP_NAME'] = sga2020_groups['GROUP_NAME']
    mock['GROUP_MULT'] = sga2020_groups['GROUP_MULT']
    mock['GROUP_RA'] = sga2020_groups['GROUP_RA']
    mock['GROUP_DEC'] = sga2020_groups['GROUP_DEC']
    mock['GROUP_DIAMETER'] = sga2020_groups['GROUP_DIAMETER'] # group_diameter
    mock['GROUP_PRIMARY'] = sga2020_groups['GROUP_PRIMARY']
    mock['SAMPLE'] = np.zeros(len(sga2020_groups), dtype=np.int32)
    mock['SGAGROUP'] = sga2020_groups['GROUP_NAME']

    if sga2020_groups_only:
        #mock['GROUP_DIAMETER'] = np.maximum(sga2020_groups['GROUP_DIAMETER'], sga2020_groups['D26'])
        pass
    else:
        # Use per-object coordinates and diameter
        mock['GROUP_RA'] = sga2020_groups['RA']
        mock['GROUP_DEC'] = sga2020_groups['DEC']
        mock['GROUP_DIAMETER'] = sga2020_groups['D26']
        mock['GROUP_MULT'] = np.ones(len(sga2020_groups), dtype=np.int16)
        mock['GROUP_PRIMARY'] = np.ones(len(sga2020_groups), dtype=bool)

    fullsample = mock
    sample = mock[mock['GROUP_PRIMARY']]

    # Find nearby SGA2025 sources to overlay
    group_coords = SkyCoord(sample['GROUP_RA'] * u.deg, sample['GROUP_DEC'] * u.deg)
    sga2025_coords = SkyCoord(fullsample_2025['RA'] * u.deg, fullsample_2025['DEC'] * u.deg)

    # For each SGA2025 source, find distance to nearest SGA2020 group center
    idx_nearest_group, sep_to_group, _ = sga2025_coords.match_to_catalog_sky(group_coords)

    # Keep SGA2025 sources within group diameter + margin
    #search_radii = sample['GROUP_DIAMETER'][idx_nearest_group]  # arcmin
    search_radii = sample['GROUP_DIAMETER'][idx_nearest_group]  # arcmin
    within_group = sep_to_group.to(u.arcmin).value < (search_radii + 1.0)  # 1' margin

    sga2025_overlay = fullsample_2025[within_group]
    log.info(f'SGA2025 sources near missing SGA2020 groups: {len(sga2025_overlay):,d}')
    #import pdb ; pdb.set_trace()

    return sample, fullsample, sga2025_overlay


